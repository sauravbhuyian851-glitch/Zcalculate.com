---
---
<div id="calc-container" class="w-full max-w-lg mx-auto transition-all duration-300">
  <div id="calc-inner-wrap" class="relative bg-canvas-card border border-canvas-card-border rounded-2xl p-3 sm:p-4 shadow-xl transition-all duration-300 w-full max-w-lg mx-auto">
    <!-- Calculator Header -->
    <div class="flex items-center justify-between mb-3 border-b border-canvas-card-border pb-3">
      <div class="text-[11px] font-bold text-mute font-mono uppercase tracking-[0.2em] py-1">
        Standard Calculator
      </div>
      <div class="flex items-center gap-4 px-1">
        <button id="calc-fullscreen" class="text-[11px] font-bold text-mute hover:text-ink transition-all flex items-center gap-1.5 uppercase tracking-wider" aria-label="Toggle Fullscreen">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Full
        </button>
        <button id="calc-float-btn" class="hidden text-[11px] font-bold text-mute hover:text-ink transition-all flex items-center gap-1.5 uppercase tracking-wider" title="Open as floating always-on-top window">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="3" width="18" height="18" rx="2" stroke-linecap="round" stroke-linejoin="round"/><path d="M13 13h5v5" stroke-linecap="round" stroke-linejoin="round"/><path d="M18 13l-5 5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Float
        </button>
        <button id="calc-clear-history" class="text-[11px] font-bold text-mute hover:text-ink transition-all flex items-center gap-1.5 uppercase tracking-wider">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Reset
        </button>
      </div>
    </div>

    <!-- Output Display Screen -->
    <div class="calc-screen bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 mb-4 flex flex-col justify-between min-h-[110px] shadow-inner font-sans relative">
      <!-- Input Part -->
      <div class="border border-solid border-canvas-card-border bg-canvas-card rounded-lg p-2.5 mb-2 w-full flex items-center justify-between transition-all relative">
        <span class="absolute -top-2.5 left-3.5 px-1 bg-canvas-card text-[8px] font-black text-mute uppercase tracking-widest select-none">Input (Paste here)</span>
        <div id="calc-display-expr" class="w-full text-left text-ink text-2xl font-semibold overflow-x-auto whitespace-nowrap scrollbar-none min-h-[32px] animate-blink">&nbsp;</div>
      </div>
      <!-- Output Part -->
      <div id="calc-display-result" class="w-full text-right text-ink text-3xl font-semibold tracking-tighter overflow-x-auto whitespace-nowrap scrollbar-none">0</div>
    </div>

    <!-- Main Pads Grid -->
    <div class="flex flex-col gap-4">
      <!-- Standard Pad -->
      <div class="grid grid-cols-4 gap-2 w-full select-none" id="calc-std-pad">
        <button class="calc-btn text-2xl sm:text-3xl font-black bg-calc-btn-soft border border-canvas-card-border text-link hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all" data-val="clear">C</button>
        <button class="calc-btn text-2xl sm:text-3xl font-black bg-calc-btn-soft border border-canvas-card-border text-mute hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all" data-val="backspace">⌫</button>
        <button class="calc-btn text-2xl sm:text-3xl font-black bg-calc-btn-soft border border-canvas-card-border text-mute hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all" data-val="percent">%</button>
        <button class="calc-btn text-2xl sm:text-3xl font-black bg-calc-btn-soft border border-canvas-card-border text-link hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all" data-val="divide">÷</button>

        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="7">7</button>
        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="8">8</button>
        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="9">9</button>
        <button class="calc-btn text-2xl sm:text-3xl font-black bg-calc-btn-soft border border-canvas-card-border text-link hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all" data-val="multiply">×</button>

        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="4">4</button>
        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="5">5</button>
        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="6">6</button>
        <button class="calc-btn text-2xl sm:text-3xl font-black bg-calc-btn-soft border border-canvas-card-border text-link hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all" data-val="subtract">-</button>

        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="1">1</button>
        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="2">2</button>
        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="3">3</button>
        <button class="calc-btn text-2xl sm:text-3xl font-black bg-calc-btn-soft border border-canvas-card-border text-link hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all" data-val="add">+</button>

        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="0">0</button>
        <button class="calc-btn text-lg sm:text-xl font-black bg-calc-btn border border-canvas-card-border text-ink hover:bg-canvas-card-soft-2 rounded-xl py-3 sm:py-3.5 transition-all shadow-sm" data-val="decimal">.</button>
        <button class="calc-btn col-span-2 text-2xl sm:text-3xl font-black bg-brand-primary hover:opacity-90 text-canvas rounded-xl py-3 sm:py-3.5 shadow-lg transition-all" data-val="equals">=</button>
      </div>
    </div>
  </div>
</div>

<script>
  function initStandardCalculator() {
    let currentExpr = '';
    let resultShown = false;

    const displayExpr = document.getElementById('calc-display-expr');
    const displayResult = document.getElementById('calc-display-result');
    const container = document.getElementById('calc-container');

    // Clean up old listeners
    const buttons = document.querySelectorAll('.calc-btn');
    buttons.forEach(btn => {
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
    });

    const freshClearHistoryBtn = document.getElementById('calc-clear-history');

    if (freshClearHistoryBtn) {
      freshClearHistoryBtn.addEventListener('click', () => {
        currentExpr = '';
        if (displayExpr) displayExpr.textContent = ' ';
        if (displayResult) displayResult.textContent = '0';
        resultShown = false;
      });
    }

    document.querySelectorAll('.calc-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-val');
        if (!val) return;

        if (val === 'clear') {
          currentExpr = '';
          if (displayExpr) displayExpr.textContent = ' ';
          if (displayResult) displayResult.textContent = '0';
          resultShown = false;
        } else if (val === 'backspace') {
          backspace();
        } else if (val === 'equals') {
          calculate();
        } else {
          let insert = val;
          if (val === 'decimal') insert = '.';
          if (val === 'percent') insert = '%';
          if (val === 'add') insert = '+';
          if (val === 'subtract') insert = '-';
          if (val === 'multiply') insert = '×';
          if (val === 'divide') insert = '÷';
          appendVal(insert);
        }
      });
    });

    function appendVal(val: string) {
      if (resultShown) {
        if (['+', '-', '×', '÷', '%'].includes(val)) {
          currentExpr = (displayResult?.textContent || '0') + val;
        } else {
          currentExpr = val;
        }
        resultShown = false;
      } else {
        if (currentExpr === '0' && !['+', '-', '×', '÷', '%', '.'].includes(val)) {
          currentExpr = val;
        } else {
          currentExpr += val;
        }
      }
      updateDisplay();
    }

    function backspace() {
      if (currentExpr.length > 0) {
        currentExpr = currentExpr.substring(0, currentExpr.length - 1);
        updateDisplay();
      }
    }

    function updateDisplay() {
      if (displayExpr) displayExpr.textContent = currentExpr || ' ';
      if (!resultShown && displayResult) {
        displayResult.textContent = '0';
      }
    }

    function calculate() {
      if (!currentExpr) return;
      try {
        let prep = currentExpr.replace(/×/g, '*').replace(/÷/g, '/');
        const result = new Function(`return ${prep}`)();
        const finalAns = typeof result === 'number' && !isNaN(result) ? Number(result.toFixed(10)).toString() : 'Error';
        if (displayResult) {
          displayResult.textContent = finalAns;
          if ((window as any).zcalculate_saveToHistory) {
            (window as any).zcalculate_saveToHistory('Standard Calculator', currentExpr, finalAns);
          }
        }
        resultShown = true;
      } catch (err) {
        if (displayResult) displayResult.textContent = 'Error';
        resultShown = true;
      }
    }

    // Keyboard support
    const handleKeyDown = (e: KeyboardEvent) => {
      const activeEl = document.activeElement;
      if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA' || activeEl.tagName === 'SELECT')) {
        return;
      }

      const key = e.key;
      
      // Ctrl+C handling
      if ((e.ctrlKey || e.metaKey) && (key === 'c' || key === 'C')) {
        const text = displayResult?.textContent || '';
        if (text && text !== '0' && text !== 'Error') {
          navigator.clipboard.writeText(text);
          e.preventDefault();
        }
        return;
      }

      if (/[0-9\.\(\)]/.test(key)) {
        appendVal(key);
      } else if (key === '+') {
        appendVal('+');
      } else if (key === '-') {
        appendVal('-');
      } else if (key === '*' || key === 'x' || key === 'X') {
        appendVal('×');
      } else if (key === '/') {
        appendVal('÷');
      } else if (key === '%') {
        appendVal('%');
      } else if (key === 'Enter' || key === '=') {
        e.preventDefault();
        calculate();
      } else if (key === 'Backspace') {
        e.preventDefault();
        backspace();
      } else if (key === 'Escape' || key === 'c' || key === 'C') {
        currentExpr = '';
        if (displayExpr) displayExpr.textContent = ' ';
        if (displayResult) displayResult.textContent = '0';
        resultShown = false;
      }
    };

    if ((window as any)._calcKeyDownHandler) {
      document.removeEventListener('keydown', (window as any)._calcKeyDownHandler);
    }
    (window as any)._calcKeyDownHandler = handleKeyDown;
    document.addEventListener('keydown', handleKeyDown);

    // Click-to-copy result
    if (displayResult) {
      displayResult.style.cursor = 'pointer';
      displayResult.setAttribute('title', 'Click to copy result');
      displayResult.onclick = () => {
        const text = displayResult.textContent || '';
        if (text && text !== '0' && text !== 'Error') {
          navigator.clipboard.writeText(text).then(() => {
            const originalColor = displayResult.className;
            displayResult.className = 'w-full text-right text-emerald-500 text-3xl font-semibold tracking-tighter overflow-x-auto whitespace-nowrap scrollbar-none';
            setTimeout(() => {
              displayResult.className = originalColor;
            }, 800);
          });
        }
      };
    }

    // Fullscreen toggling using HTML5 Fullscreen API
    const fullscreenBtn = document.getElementById('calc-fullscreen');
    
    const applyFullscreenLayout = () => {
      const isCurrentlyFullscreen = document.fullscreenElement === container;
      if (isCurrentlyFullscreen) {
        if (fullscreenBtn) {
          fullscreenBtn.innerHTML = `
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 14h6v6m10-6h-6v6M4 10h6V4m10 6h-6V4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Exit
          `;
        }
      } else {
        if (fullscreenBtn) {
          fullscreenBtn.innerHTML = `
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Full
          `;
        }
      }
    };

    if (fullscreenBtn && container) {
      fullscreenBtn.onclick = (e) => {
        e.preventDefault();
        e.stopPropagation();
        if (!document.fullscreenElement) {
          container.requestFullscreen().catch(err => {
            console.error(`Fullscreen request failed: ${err.message}`);
          });
        } else {
          document.exitFullscreen();
        }
      };

      document.addEventListener('fullscreenchange', applyFullscreenLayout);
      applyFullscreenLayout();
    }

    // Floating Window / Picture-in-Picture handler
    const floatBtn = document.getElementById('calc-float-btn');
    if (floatBtn && 'documentPictureInPicture' in window) {
      floatBtn.classList.remove('hidden');

      floatBtn.onclick = async (e) => {
        e.preventDefault();
        e.stopPropagation();

        if (!container) return;

        try {
          // Request PiP window
          const pipWindow = await (window as any).documentPictureInPicture.requestWindow({
            width: 360,
            height: 520,
          });

          // Sync stylesheets
          [...document.styleSheets].forEach((styleSheet) => {
            try {
              const cssRules = [...styleSheet.cssRules].map((rule) => rule.cssText).join('');
              const style = document.createElement('style');
              style.textContent = cssRules;
              pipWindow.document.head.appendChild(style);
            } catch (e) {
              const link = document.createElement('link');
              if (styleSheet.href) {
                link.rel = 'stylesheet';
                link.href = styleSheet.href;
                pipWindow.document.head.appendChild(link);
              }
            }
          });

          // Sync theme
          if (document.documentElement.classList.contains('dark')) {
            pipWindow.document.documentElement.classList.add('dark');
          }

          // Format body styling
          pipWindow.document.body.className = document.body.className;
          pipWindow.document.body.style.backgroundColor = 'var(--canvas-soft)';
          pipWindow.document.body.style.display = 'flex';
          pipWindow.document.body.style.justifyContent = 'center';
          pipWindow.document.body.style.alignItems = 'center';
          pipWindow.document.body.style.height = '100vh';
          pipWindow.document.body.style.margin = '0';
          pipWindow.document.body.style.padding = '12px';
          pipWindow.document.body.style.boxSizing = 'border-box';

          // Hide fullscreen and float buttons inside PiP window to prevent window-inside-window glitches
          const fsInPip = container.querySelector('#calc-fullscreen');
          const floatInPip = container.querySelector('#calc-float-btn');
          if (fsInPip) (fsInPip as HTMLElement).style.display = 'none';
          if (floatInPip) (floatInPip as HTMLElement).style.display = 'none';

          // Create a placeholder where the element was
          const placeholder = document.createElement('div');
          placeholder.id = 'calc-placeholder';
          // Ensure placeholder has the exact visual size/border style so it doesn't cause page jumps
          placeholder.className = 'bg-canvas-card-soft border border-dashed border-canvas-card-border rounded-2xl h-96 flex items-center justify-center text-mute font-bold text-xs select-none';
          placeholder.textContent = 'Calculator is floating on top';
          
          container.parentNode?.replaceChild(placeholder, container);
          pipWindow.document.body.appendChild(container);

          // Restore element when PiP window is closed
          pipWindow.addEventListener('pagehide', () => {
            const pl = document.getElementById('calc-placeholder');
            if (pl) {
              // Restore buttons display
              if (fsInPip) (fsInPip as HTMLElement).style.display = '';
              if (floatInPip) (floatInPip as HTMLElement).style.display = '';
              pl.parentNode?.replaceChild(container, pl);
            }
          });
        } catch (err) {
          console.error(`Failed to open floating window: ${err}`);
        }
      };
    }
  }

  initStandardCalculator();
  document.addEventListener('astro:after-swap', initStandardCalculator);
</script>

<style is:global>
  @keyframes calc-caret-blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  
  .animate-blink::after {
    content: '' !important;
    display: inline-block !important;
    width: 2px !important;
    height: 1.25rem !important;
    background-color: currentColor !important;
    animation: calc-caret-blink 1s step-end infinite !important;
    margin-left: 2px !important;
    vertical-align: middle !important;
    margin-bottom: 2px !important;
  }
</style>
