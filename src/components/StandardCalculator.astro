---
---
<div id="calc-container" class="w-full max-w-lg mx-auto md:max-w-2xl transition-all duration-300">
  <div id="calc-inner-wrap" class="relative bg-canvas border border-hairline rounded-2xl p-4 shadow-xl transition-all duration-300 w-full max-w-lg">
    <!-- Calculator Header / Modes -->
    <div class="flex items-center justify-between mb-3 border-b border-hairline pb-3">
      <div class="flex items-center gap-1.5 p-1 bg-canvas-soft rounded-lg">
        <button id="calc-mode-std" class="px-4 py-1 rounded-md text-[11px] font-bold bg-canvas text-ink shadow-sm transition-all uppercase tracking-wider">Standard</button>
        <button id="calc-mode-sci" class="px-4 py-1 rounded-md text-[11px] font-bold text-mute hover:text-ink transition-all uppercase tracking-wider">Scientific</button>
      </div>
      <div class="flex items-center gap-4">
        <!-- Degree / Radian Toggle -->
        <span id="deg-rad-indicator" class="hidden font-mono text-[10px] font-bold text-mute uppercase tracking-widest bg-canvas-soft border border-hairline px-2.5 py-1 rounded">DEG</span>
        <button id="calc-fullscreen" class="text-[11px] font-bold text-mute hover:text-ink transition-all flex items-center gap-1.5 uppercase tracking-wider" aria-label="Toggle Fullscreen">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Full
        </button>
        <button id="calc-clear-history" class="text-[11px] font-bold text-mute hover:text-ink transition-all flex items-center gap-1.5 uppercase tracking-wider">
          <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Reset
        </button>
      </div>
    </div>

    <!-- Output Display Screen -->
    <div class="bg-canvas-soft border border-hairline rounded-xl p-4 mb-4 flex flex-col justify-between min-h-[110px] shadow-inner font-sans relative">
      <!-- Input Part -->
      <div class="border border-dashed border-hairline-strong/45 rounded-lg p-2.5 mb-2 w-full flex items-center justify-between transition-all relative">
        <span class="absolute -top-2.5 left-3.5 px-1 bg-canvas-soft text-[8px] font-black text-mute uppercase tracking-widest select-none">Input (Paste here)</span>
        <div id="calc-display-expr" class="w-full text-left text-mute text-2xl font-semibold overflow-x-auto whitespace-nowrap scrollbar-none min-h-[32px] animate-blink">&nbsp;</div>
      </div>
      <!-- Output Part -->
      <div id="calc-display-result" class="w-full text-right text-ink text-3xl font-semibold tracking-tighter overflow-x-auto whitespace-nowrap scrollbar-none">0</div>
    </div>

    <!-- Main Pads Grid -->
    <div class="flex flex-col gap-4">
      <!-- Scientific Pad (collapsible) -->
      <div id="calc-sci-pad" class="hidden grid-cols-5 gap-2 w-full select-none">
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="sin">sin</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="cos">cos</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="tan">tan</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="pi">π</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="e">e</button>

        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="asin">sin⁻¹</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="acos">cos⁻¹</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="atan">tan⁻¹</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="pow">xʸ</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="sqrt">√</button>

        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="log">log</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="ln">ln</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="fact">x!</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val="(">(</button>
        <button class="calc-btn text-sm font-black bg-canvas border border-hairline text-body hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase" data-val=")">)</button>

        <button id="calc-toggle-deg" class="col-span-5 calc-btn text-[10px] font-black bg-canvas-soft border border-hairline text-mute hover:bg-canvas-soft-2 hover:text-ink rounded-lg py-2 flex items-center justify-center transition-all uppercase tracking-wider mt-1.5">Toggle Radian Mode</button>
      </div>

      <!-- Standard Pad -->
      <div class="grid grid-cols-4 gap-2 w-full select-none" id="calc-std-pad">
        <button class="calc-btn text-3xl font-black bg-canvas-soft border border-hairline text-link hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all" data-val="clear">C</button>
        <button class="calc-btn text-3xl font-black bg-canvas-soft border border-hairline text-mute hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all" data-val="backspace">⌫</button>
        <button class="calc-btn text-3xl font-black bg-canvas-soft border border-hairline text-mute hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all" data-val="percent">%</button>
        <button class="calc-btn text-3xl font-black bg-canvas-soft border border-hairline text-link hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all" data-val="divide">÷</button>

        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="7">7</button>
        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="8">8</button>
        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="9">9</button>
        <button class="calc-btn text-3xl font-black bg-canvas-soft border border-hairline text-link hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all" data-val="multiply">×</button>

        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="4">4</button>
        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="5">5</button>
        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="6">6</button>
        <button class="calc-btn text-3xl font-black bg-canvas-soft border border-hairline text-link hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all" data-val="subtract">-</button>

        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="1">1</button>
        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="2">2</button>
        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="3">3</button>
        <button class="calc-btn text-3xl font-black bg-canvas-soft border border-hairline text-link hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all" data-val="add">+</button>

        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="0">0</button>
        <button class="calc-btn text-xl font-black bg-canvas border border-hairline text-ink hover:bg-canvas-soft-2 rounded-xl py-3.5 transition-all shadow-sm" data-val="decimal">.</button>
        <button class="calc-btn col-span-2 text-3xl font-black bg-brand-primary hover:opacity-90 text-canvas rounded-xl py-3.5 shadow-lg transition-all" data-val="equals">=</button>
      </div>
    </div>
  </div>
</div>

<script>
  function initStandardCalculator() {
    let mode = 'std'; // std or sci
    let isRadians = false; // degree default, false
    let currentExpr = '';
    let resultShown = false;

    const stdBtn = document.getElementById('calc-mode-std');
    const sciBtn = document.getElementById('calc-mode-sci');
    const sciPad = document.getElementById('calc-sci-pad');
    const stdPad = document.getElementById('calc-std-pad');
    const toggleDegBtn = document.getElementById('calc-toggle-deg');
    const degRadIndicator = document.getElementById('deg-rad-indicator');
    const displayExpr = document.getElementById('calc-display-expr');
    const displayResult = document.getElementById('calc-display-result');
    const clearHistoryBtn = document.getElementById('calc-clear-history');
    const container = document.getElementById('calc-container');
    const innerWrap = document.getElementById('calc-inner-wrap');
    const fullscreenBtn = document.getElementById('calc-fullscreen');
    let isFullscreen = sessionStorage.getItem('calc_fullscreen') === 'true';

    // Clean up old listeners
    const buttons = document.querySelectorAll('.calc-btn');
    buttons.forEach(btn => {
      const newBtn = btn.cloneNode(true);
      btn.parentNode.replaceChild(newBtn, btn);
    });

    // Re-select fresh nodes
    const freshStdBtn = document.getElementById('calc-mode-std');
    const freshSciBtn = document.getElementById('calc-mode-sci');
    const freshSciPad = document.getElementById('calc-sci-pad');
    const freshToggleDegBtn = document.getElementById('calc-toggle-deg');
    const freshClearHistoryBtn = document.getElementById('calc-clear-history');

    if (freshStdBtn && freshSciBtn && freshSciPad) {
      freshStdBtn.addEventListener('click', () => {
        mode = 'std';
        freshStdBtn.className = "px-4 py-1 rounded-md text-[11px] font-bold bg-canvas text-ink shadow-sm transition-all uppercase tracking-wider";
        freshSciBtn.className = "px-4 py-1 rounded-md text-[11px] font-bold text-mute hover:text-ink transition-all uppercase tracking-wider";
        freshSciPad.style.display = 'none';
        freshSciPad.classList.remove('calc-sci-active');
        if (stdPad) stdPad.className = "grid grid-cols-4 gap-2 w-full select-none";
        if (innerWrap) innerWrap.classList.remove('calc-sci-active-wrap');
        if (!isFullscreen) {
          if (container) container.className = "w-full max-w-lg mx-auto transition-all duration-300";
          if (innerWrap) innerWrap.className = "relative bg-canvas border border-hairline rounded-2xl p-4 shadow-xl transition-all duration-300 w-full max-w-lg";
        }
        if (degRadIndicator) degRadIndicator.classList.add('hidden');
      });

      freshSciBtn.addEventListener('click', () => {
        mode = 'sci';
        freshSciBtn.className = "px-4 py-1 rounded-md text-[11px] font-bold bg-canvas text-ink shadow-sm transition-all uppercase tracking-wider";
        freshStdBtn.className = "px-4 py-1 rounded-md text-[11px] font-bold text-mute hover:text-ink transition-all uppercase tracking-wider";
        freshSciPad.style.display = 'grid';
        freshSciPad.classList.add('calc-sci-active');
        if (stdPad) stdPad.className = "grid grid-cols-4 gap-2 w-full select-none calc-sci-active";
        if (innerWrap) innerWrap.classList.add('calc-sci-active-wrap');
        if (!isFullscreen) {
          if (container) container.className = "w-full max-w-lg mx-auto md:max-w-2xl transition-all duration-300";
          if (innerWrap) innerWrap.className = "relative bg-canvas border border-hairline rounded-2xl p-4 shadow-xl transition-all duration-300 w-full md:max-w-2xl max-w-lg mx-auto";
        }
        if (degRadIndicator) degRadIndicator.classList.remove('hidden');
        updateDegRadIndicator();
      });
    }

    function updateDegRadIndicator() {
      if (degRadIndicator && freshToggleDegBtn) {
        if (isRadians) {
          degRadIndicator.textContent = 'RAD';
          freshToggleDegBtn.textContent = 'Toggle Degree Mode';
        } else {
          degRadIndicator.textContent = 'DEG';
          freshToggleDegBtn.textContent = 'Toggle Radian Mode';
        }
      }
    }

    if (freshToggleDegBtn) {
      freshToggleDegBtn.addEventListener('click', () => {
        isRadians = !isRadians;
        updateDegRadIndicator();
      });
    }

    if (freshClearHistoryBtn) {
      freshClearHistoryBtn.addEventListener('click', () => {
        currentExpr = '';
        if (displayExpr) displayExpr.textContent = ' ';
        if (displayResult) displayResult.textContent = '\u00A0';
        resultShown = false;
      });
    }

    document.querySelectorAll('.calc-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const val = btn.getAttribute('data-val');
        if (!val || val === 'std' || val === 'sci') return;

        if (val === 'clear') {
          currentExpr = '';
          if (displayExpr) displayExpr.textContent = ' ';
          if (displayResult) displayResult.textContent = '\u00A0';
          resultShown = false;
        } else if (val === 'backspace') {
          backspace();
        } else if (val === 'equals') {
          calculate();
        } else {
          let insert = val;
          if (val === 'decimal') insert = '.';
          if (val === 'percent') insert = '%';
          if (val === 'add') insert = '+';
          if (val === 'subtract') insert = '-';
          if (val === 'multiply') insert = '×';
          if (val === 'divide') insert = '÷';
          if (['sin', 'cos', 'tan', 'asin', 'acos', 'atan', 'log', 'ln', 'sqrt'].includes(val)) insert = val + '(';
          if (val === 'pi') insert = 'π';
          if (val === 'e') insert = 'e';
          if (val === 'pow') insert = '^';
          if (val === 'fact') insert = '!';
          appendVal(insert);
        }
      });
    });

    function appendVal(val: string) {
      if (resultShown) {
        if (['+', '-', '×', '÷', '^', '%', '!'].includes(val)) {
          currentExpr = (displayResult?.textContent || '0') + val;
        } else {
          currentExpr = val;
        }
        resultShown = false;
      } else {
        if (currentExpr === '0' && !['+', '-', '×', '÷', '^', '%', '!', '.'].includes(val)) {
          currentExpr = val;
        } else {
          currentExpr += val;
        }
      }
      updateDisplay();
    }

    function backspace() {
      if (currentExpr.length > 0) {
        const matchedFunc = ['asin(', 'acos(', 'atan(', 'sin(', 'cos(', 'tan(', 'log(', 'ln(', 'sqrt('].find(f => currentExpr.endsWith(f));
        currentExpr = matchedFunc ? currentExpr.substring(0, currentExpr.length - matchedFunc.length) : currentExpr.substring(0, currentExpr.length - 1);
        updateDisplay();
      }
    }

    function updateDisplay() {
      if (displayExpr) displayExpr.textContent = currentExpr || ' ';
      if (!resultShown && displayResult) {
        displayResult.textContent = '\u00A0';
      }
    }

    function calculate() {
      if (!currentExpr) return;
      try {
        let prep = currentExpr.replace(/×/g, '*').replace(/÷/g, '/').replace(/π/g, 'Math.PI').replace(/e/g, 'Math.E');
        prep = prep.replace(/(\d+(?:\.\d+)?)\!/g, (_, n) => {
          let r = 1; for (let i = 2; i <= n; i++) r *= i; return r.toString();
        });
        const d2r = (Math.PI / 180);
        if (!isRadians) {
          prep = prep.replace(/sin\(/g, `Math.sin(${d2r}*`).replace(/cos\(/g, `Math.cos(${d2r}*`).replace(/tan\(/g, `Math.tan(${d2r}*`)
                     .replace(/asin\(/g, `(1/${d2r})*Math.asin(`).replace(/acos\(/g, `(1/${d2r})*Math.acos(`).replace(/atan\(/g, `(1/${d2r})*Math.atan(`);
        } else {
          prep = prep.replace(/sin\(/g, 'Math.sin(').replace(/cos\(/g, 'Math.cos(').replace(/tan\(/g, 'Math.tan(');
        }
        prep = prep.replace(/ln\(/g, 'Math.log(').replace(/log\(/g, 'Math.log10(').replace(/sqrt\(/g, 'Math.sqrt(').replace(/\^/g, '**');

        const result = new Function(`return ${prep}`)();
        const finalAns = typeof result === 'number' && !isNaN(result) ? Number(result.toFixed(10)).toString() : 'Error';
        if (displayResult) {
          displayResult.textContent = finalAns;
        }
        resultShown = true;
        
        saveToHistory('Standard Calculator', currentExpr, finalAns);
      } catch (err) {
        if (displayResult) displayResult.textContent = 'Error';
        resultShown = true;
      }
    }

    function saveToHistory(calcName: string, query: string, resVal: string) {
      try {
        const raw = localStorage.getItem('zcalculate_history') || '[]';
        const history = JSON.parse(raw);
        history.unshift({
          timestamp: Date.now(),
          calculator: calcName,
          query,
          result: resVal
        });
        localStorage.setItem('zcalculate_history', JSON.stringify(history.slice(0, 100)));
      } catch (e) {
        console.error('History write failure', e);
      }
    }

    // Keyboard support
    const handleKeyDown = (e: KeyboardEvent) => {
      const activeEl = document.activeElement;
      if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA' || activeEl.tagName === 'SELECT')) {
        return;
      }

      const key = e.key;
      
      // Ctrl+C handling
      if ((e.ctrlKey || e.metaKey) && (key === 'c' || key === 'C')) {
        const text = displayResult?.textContent || '';
        if (text && text !== '\u00A0' && text !== '0' && text !== 'Error') {
          navigator.clipboard.writeText(text);
          e.preventDefault();
        }
        return;
      }

      if (/[0-9\.\(\)]/.test(key)) {
        appendVal(key);
      } else if (key === '+') {
        appendVal('+');
      } else if (key === '-') {
        appendVal('-');
      } else if (key === '*' || key === 'x' || key === 'X') {
        appendVal('×');
      } else if (key === '/') {
        appendVal('÷');
      } else if (key === '%') {
        appendVal('%');
      } else if (key === 'Enter' || key === '=') {
        e.preventDefault();
        calculate();
      } else if (key === 'Backspace') {
        e.preventDefault();
        backspace();
      } else if (key === 'Escape' || key === 'c' || key === 'C') {
        currentExpr = '';
        if (displayExpr) displayExpr.textContent = ' ';
        if (displayResult) displayResult.textContent = '\u00A0';
        resultShown = false;
      }
    };

    if ((window as any)._calcKeyDownHandler) {
      document.removeEventListener('keydown', (window as any)._calcKeyDownHandler);
    }
    (window as any)._calcKeyDownHandler = handleKeyDown;
    document.addEventListener('keydown', handleKeyDown);

    // Paste handling
    const handlePaste = (e: ClipboardEvent) => {
      const activeEl = document.activeElement;
      if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA' || activeEl.tagName === 'SELECT')) {
        return;
      }
      const text = e.clipboardData?.getData('text') || '';
      const filtered = text.replace(/[^0-9\.\+\-\*\/\%\(\)xX÷×]/g, '')
                          .replace(/x|X/g, '×')
                          .replace(/\*/g, '×')
                          .replace(/\//g, '÷');
      if (filtered) {
        appendVal(filtered);
      }
    };

    if ((window as any)._calcPasteHandler) {
      document.removeEventListener('paste', (window as any)._calcPasteHandler);
    }
    (window as any)._calcPasteHandler = handlePaste;
    document.addEventListener('paste', handlePaste);

    // Click-to-copy result
    if (displayResult) {
      displayResult.style.cursor = 'pointer';
      displayResult.setAttribute('title', 'Click to copy result');
      displayResult.onclick = () => {
        const text = displayResult.textContent || '';
        if (text && text !== '\u00A0' && text !== '0' && text !== 'Error') {
          navigator.clipboard.writeText(text).then(() => {
            const originalColor = displayResult.className;
            displayResult.className = 'w-full text-right text-emerald-500 text-3xl font-semibold tracking-tighter overflow-x-auto whitespace-nowrap scrollbar-none';
            setTimeout(() => {
              displayResult.className = originalColor;
            }, 800);
          });
        }
      };
    }

    // Fullscreen toggling
    const applyFullscreenLayout = () => {
      if (isFullscreen) {
        if (container) container.className = "w-full max-w-none fixed inset-0 z-[100] bg-canvas/98 overflow-y-auto p-4 md:p-8 flex justify-center items-start";
        if (innerWrap) innerWrap.className = "relative bg-canvas border border-hairline rounded-2xl p-4 shadow-xl transition-all duration-300 w-full max-w-lg md:max-w-2xl my-auto";
        if (fullscreenBtn) {
          fullscreenBtn.innerHTML = `
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 14h6v6m10-6h-6v6M4 10h6V4m10 6h-6V4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Exit
          `;
        }
      } else {
        if (mode === 'std') {
          if (container) container.className = "w-full max-w-lg mx-auto transition-all duration-300";
          if (innerWrap) innerWrap.className = "relative bg-canvas border border-hairline rounded-2xl p-4 shadow-xl transition-all duration-300 w-full max-w-lg";
        } else {
          if (container) container.className = "w-full max-w-lg mx-auto md:max-w-2xl transition-all duration-300";
          if (innerWrap) innerWrap.className = "relative bg-canvas border border-hairline rounded-2xl p-4 shadow-xl transition-all duration-300 w-full md:max-w-2xl max-w-lg mx-auto";
        }
        if (fullscreenBtn) {
          fullscreenBtn.innerHTML = `
            <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Full
          `;
        }
      }
    };

    if (fullscreenBtn && container) {
      fullscreenBtn.onclick = (e) => {
        e.preventDefault();
        e.stopPropagation();
        isFullscreen = !isFullscreen;
        sessionStorage.setItem('calc_fullscreen', String(isFullscreen));
        applyFullscreenLayout();
      };
      
      // Initialize layout based on saved state
      applyFullscreenLayout();
    }
  }

  initStandardCalculator();
  document.addEventListener('astro:after-swap', initStandardCalculator);
</script>

