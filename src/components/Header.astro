---
---
<header class="sticky top-0 z-50 w-full h-16 border-b border-hairline bg-canvas/80 backdrop-blur-md transition-colors">
  <div class="mx-auto flex h-full max-w-7xl items-center justify-between px-6">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 group">
      <svg class="h-6 w-6 text-ink transition-transform group-hover:scale-105" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="9" y1="9" x2="15" y2="9"></line>
        <line x1="9" y1="13" x2="15" y2="13"></line>
        <line x1="9" y1="17" x2="15" y2="17"></line>
        <line x1="12" y1="9" x2="12" y2="17"></line>
      </svg>
      <span class="font-sans text-xl font-semibold tracking-tight text-ink">Zcalculate<span class="text-link">.</span></span>
    </a>

    <!-- Desktop Nav Links -->
    <nav class="hidden md:flex items-center gap-2">
      <a href="/" class="px-3 py-1.5 text-sm font-bold text-ink hover:text-ink hover:bg-canvas-soft rounded-md transition-all">Home</a>
      <a href="/calculator/scientific-calculator" class="px-4 py-1.5 text-sm font-black bg-brand-primary text-canvas rounded-full hover:opacity-90 transition-all shadow-sm">Scientific</a>
      
      <!-- Dropdown Wrapper -->
      <div class="relative dropdown-container">
        <button id="all-tools-btn" class="inline-flex items-center gap-1.5 px-3 py-1.5 text-sm font-bold text-ink hover:bg-canvas-soft rounded-md transition-all cursor-pointer select-none">
          All Tools
          <svg class="h-4 w-4 text-mute transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <!-- Dropdown Menu -->
        <div id="all-tools-dropdown" class="hidden absolute top-full left-0 mt-2 w-56 bg-canvas-card border border-canvas-card-border rounded-xl shadow-xl z-50 p-2 text-left">
          <a href="/#all-calculators" data-cat="financial" class="cat-link block px-4 py-2.5 text-xs font-bold text-body hover:text-ink hover:bg-canvas-soft rounded-lg transition-all">Financial</a>
          <a href="/#all-calculators" data-cat="health" class="cat-link block px-4 py-2.5 text-xs font-bold text-body hover:text-ink hover:bg-canvas-soft rounded-lg transition-all">Fitness & Health</a>
          <a href="/#all-calculators" data-cat="math" class="cat-link block px-4 py-2.5 text-xs font-bold text-body hover:text-ink hover:bg-canvas-soft rounded-lg transition-all">Math & Science</a>
          <a href="/#all-calculators" data-cat="other" class="cat-link block px-4 py-2.5 text-xs font-bold text-body hover:text-ink hover:bg-canvas-soft rounded-lg transition-all">Other Tools</a>
        </div>
      </div>
    </nav>

    <!-- Right Side CTA/Actions -->
    <div class="hidden md:flex items-center gap-3">
      <!-- Theme Toggle -->
      <button id="theme-toggle" class="flex h-8 w-8 items-center justify-center rounded-md border border-hairline bg-canvas text-mute hover:bg-canvas-soft hover:text-ink transition-all shadow-sm" aria-label="Toggle Theme">
        <svg id="sun-icon" class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
        <svg id="moon-icon" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
    </div>

    <!-- Mobile Menu Button -->
    <div class="flex items-center gap-2 md:hidden">
      <button id="theme-toggle-mobile" class="flex h-9 w-9 items-center justify-center rounded-md border border-hairline bg-canvas text-mute shadow-sm" aria-label="Toggle Theme">
        <svg class="sun-icon-m hidden h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="5"></circle><path d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path></svg>
        <svg class="moon-icon-m h-4.5 w-4.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
      </button>
      <button id="mobile-menu-toggle" class="flex items-center justify-center p-2 text-mute hover:text-ink" aria-label="Toggle Menu">
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Dropdown Menu -->
  <div id="mobile-menu" class="hidden border-b border-hairline bg-canvas px-6 py-6 md:hidden">
    <nav class="flex flex-col gap-4 text-left">
      <a href="/" class="text-sm font-bold text-ink hover:bg-canvas-soft p-2 rounded-md">Home</a>
      <a href="/calculator/scientific-calculator" class="text-sm font-black bg-brand-primary text-canvas p-2.5 rounded-lg text-center shadow-md">Scientific</a>
      <div class="border-t border-hairline my-2"></div>
      <p class="text-[10px] font-bold text-mute uppercase tracking-widest px-2">All Tools Categories</p>
      <a href="/#all-calculators" data-cat="financial" class="cat-link text-sm font-bold text-body hover:text-ink p-2 pl-4">Financial</a>
      <a href="/#all-calculators" data-cat="health" class="cat-link text-sm font-bold text-body hover:text-ink p-2 pl-4">Fitness & Health</a>
      <a href="/#all-calculators" data-cat="math" class="cat-link text-sm font-bold text-body hover:text-ink p-2 pl-4">Math & Science</a>
      <a href="/#all-calculators" data-cat="other" class="cat-link text-sm font-bold text-body hover:text-ink p-2 pl-4">Other Tools</a>
    </nav>
  </div>
</header>

<script>
  function setupHeader() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    if (toggleBtn && mobileMenu) {
      toggleBtn.replaceWith(toggleBtn.cloneNode(true));
      const activeToggleBtn = document.getElementById('mobile-menu-toggle');
      if (activeToggleBtn) {
        activeToggleBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
        });
      }
    }

    const themeToggle = document.getElementById('theme-toggle');
    const themeToggleMobile = document.getElementById('theme-toggle-mobile');

    if (themeToggle) {
      themeToggle.replaceWith(themeToggle.cloneNode(true));
    }
    if (themeToggleMobile) {
      themeToggleMobile.replaceWith(themeToggleMobile.cloneNode(true));
    }

    const activeThemeToggle = document.getElementById('theme-toggle');
    const activeThemeToggleMobile = document.getElementById('theme-toggle-mobile');

    function updateIcons(isDark: boolean) {
      const sunIcons = document.querySelectorAll('#sun-icon, .sun-icon-m');
      const moonIcons = document.querySelectorAll('#moon-icon, .moon-icon-m');
      sunIcons.forEach(icon => isDark ? icon.classList.remove('hidden') : icon.classList.add('hidden'));
      moonIcons.forEach(icon => isDark ? icon.classList.add('hidden') : icon.classList.remove('hidden'));
    }

    function toggleTheme() {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
      updateIcons(isDark);
      
      // Notify other components of theme change
      window.dispatchEvent(new Event('theme-changed'));
    }

    if (activeThemeToggle) {
      activeThemeToggle.addEventListener('click', toggleTheme);
    }
    if (activeThemeToggleMobile) {
      activeThemeToggleMobile.addEventListener('click', toggleTheme);
    }

    // All Tools Dropdown Toggle
    const allToolsBtn = document.getElementById('all-tools-btn');
    const allToolsDropdown = document.getElementById('all-tools-dropdown');
    
    if (allToolsBtn && allToolsDropdown) {
      allToolsBtn.onclick = (e) => {
        e.stopPropagation();
        allToolsDropdown.classList.toggle('hidden');
        const arrow = allToolsBtn.querySelector('svg');
        if (arrow) arrow.classList.toggle('rotate-180');
      };

      document.addEventListener('click', (e) => {
        if (!allToolsDropdown.classList.contains('hidden')) {
          const target = e.target as HTMLElement;
          if (!target.closest('.dropdown-container')) {
            allToolsDropdown.classList.add('hidden');
            const arrow = allToolsBtn.querySelector('svg');
            if (arrow) arrow.classList.remove('rotate-180');
          }
        }
      });
    }

    // Category click storage & scrolling filter integration
    const catLinks = document.querySelectorAll('.cat-link');
    catLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        const cat = link.getAttribute('data-cat');
        if (cat) {
          localStorage.setItem('zcalculate_active_category', cat);
          
          if (window.location.pathname === '/') {
            e.preventDefault();
            const filterBtn = document.querySelector(`.filter-tab[data-category="${cat}"]`) as HTMLButtonElement;
            if (filterBtn) {
              filterBtn.click();
              const section = document.getElementById('all-calculators');
              if (section) {
                section.scrollIntoView({ behavior: 'smooth' });
              }
            }
            if (allToolsDropdown) allToolsDropdown.classList.add('hidden');
            const arrow = allToolsBtn?.querySelector('svg');
            if (arrow) arrow.classList.remove('rotate-180');
            if (mobileMenu) mobileMenu.classList.add('hidden');
          }
        }
      });
    });

    updateIcons(document.documentElement.classList.contains('dark'));
  }

  // Initial setup and re-run on transition
  setupHeader();
  document.addEventListener('astro:after-swap', setupHeader);
</script>
