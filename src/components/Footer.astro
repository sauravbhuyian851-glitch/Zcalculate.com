      </div>
      <div class="flex gap-6">
        <a href="/calculator/screen-size-calculator" class="text-xs text-mute hover:text-ink transition-colors">Calibration</a>
        <a href="/#all-calculators" class="text-xs text-mute hover:text-ink transition-colors">Library</a>
        <a href="/#all-calculators" class="text-xs text-mute hover:text-ink transition-colors">All Tools</a>
