<footer class="border-t border-hairline bg-canvas py-16 px-6 transition-colors">
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-2 gap-12 md:grid-cols-4">
      <div>
        <h3 class="font-mono text-[11px] font-semibold tracking-widest text-mute uppercase">Financial</h3>
        <ul class="mt-6 space-y-3">
          <li><a href="/calculator/mortgage-calculator" class="text-sm text-body hover:text-ink transition-colors">Mortgage Calculator</a></li>
          <li><a href="/calculator/loan-calculator" class="text-sm text-body hover:text-ink transition-colors">Loan Calculator</a></li>
          <li><a href="/calculator/compound-interest-calculator" class="text-sm text-body hover:text-ink transition-colors">Compound Interest</a></li>
          <li><a href="/calculator/salary-calculator" class="text-sm text-body hover:text-ink transition-colors">Salary Calculator</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-mono text-[11px] font-semibold tracking-widest text-mute uppercase">Fitness & Health</h3>
