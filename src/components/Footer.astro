        </ul>
      </div>
      <div>
        <h3 class="font-mono text-[11px] font-semibold tracking-widest text-mute uppercase">Math & Science</h3>
        <ul class="mt-6 space-y-3">
          <li><a href="/calculator/scientific-calculator" class="text-sm text-body hover:text-ink transition-colors">Scientific Calculator</a></li>
          <li><a href="/calculator/fraction-calculator" class="text-sm text-body hover:text-ink transition-colors">Fraction Calculator</a></li>
          <li><a href="/calculator/percentage-calculator" class="text-sm text-body hover:text-ink transition-colors">Percentage Calculator</a></li>
          <li><a href="/calculator/triangle-calculator" class="text-sm text-body hover:text-ink transition-colors">Triangle Calculator</a></li>
