          <li><a href="/calculator/subnet-calculator" class="text-sm text-body hover:text-ink transition-colors">Subnet Calculator</a></li>
          <li><a href="/calculator/password-generator" class="text-sm text-body hover:text-ink transition-colors">Password Generator</a></li>
          <li><a href="/calculator/screen-size-calculator" class="text-sm text-body hover:text-ink transition-colors">Screen Calibrator</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-16 border-t border-hairline pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="9" y1="9" x2="15" y2="9"></line>
          <line x1="9" y1="13" x2="15" y2="13"></line>
