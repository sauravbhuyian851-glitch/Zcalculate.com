              <input type="checkbox" id={`pass-${opt.toLowerCase()}`} class="peer accent-indigo-600 h-5 w-5 rounded border-canvas-card-border transition-all" checked />
            </div>
            <span class="text-sm font-semibold text-body group-hover:text-ink transition-colors">{opt} cases</span>
          </label>
        ))}
