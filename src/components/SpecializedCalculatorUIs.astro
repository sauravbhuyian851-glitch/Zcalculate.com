      </div>
      <div class="flex justify-between items-center py-2 border-b border-canvas-card-border">
        <span class="text-[10px] font-bold text-mute uppercase tracking-widest">Network ID</span>
        <span id="sub-net" class="text-sm font-bold text-ink font-mono">-</span>
      </div>
      <div class="flex justify-between items-center py-2 border-b border-canvas-card-border">
        <span class="text-[10px] font-bold text-mute uppercase tracking-widest">Broadcast</span>
        <span id="sub-broadcast" class="text-sm font-bold text-ink font-mono">-</span>
      </div>
      <div class="flex justify-between items-center py-2">
        <span class="text-[10px] font-bold text-mute uppercase tracking-widest">Total Usable</span>
        <span id="sub-hosts" class="text-sm font-bold text-link">-</span>
      </div>
    </div>
    
    <button id="sub-calculate" class="w-full h-14 rounded-xl bg-brand-primary hover:opacity-90 text-canvas font-black text-lg transition-all shadow-lg uppercase tracking-tight">Compute Mask</button>
  </div>
