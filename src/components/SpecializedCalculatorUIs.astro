      <div class="flex flex-col">
        <span class="text-[10px] font-bold text-mute uppercase tracking-widest mb-1">Entropy</span>
        <span id="pass-entropy" class="text-base font-bold text-ink">-</span>
      </div>
    </div>

    <button id="pass-generate" class="w-full h-14 rounded-xl bg-brand-primary hover:opacity-90 text-canvas font-black text-lg transition-all shadow-lg uppercase tracking-tight">Generate Key</button>
  </div>
)}

<!-- ==================== TRIANGLE CALCULATOR ==================== -->
