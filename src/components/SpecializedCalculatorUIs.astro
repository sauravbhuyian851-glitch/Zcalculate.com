---
interface Props {
  type: string;
}

const { type } = Astro.props;
---

<!-- ==================== SCIENTIFIC CALCULATOR STANDALONE (4-MODE) ==================== -->
{type === 'scientific-calculator' && (
  <div class="space-y-6" id="sci-calc-root">
    <!-- ===== MODE TAB BAR ===== -->
    <div class="flex items-center p-1 bg-canvas-card-soft-2 border border-canvas-card-border rounded-xl gap-1 overflow-x-auto shadow-sm">
      {['standard', 'programmable', 'graphing', 'cas'].map(mode => (
        <button
          class={`sci-mode-tab flex-1 min-w-[80px] px-3 py-2 rounded-lg text-[10px] sm:text-xs font-bold transition-all uppercase tracking-wider whitespace-nowrap ${mode === 'standard' ? 'bg-calc-btn text-ink shadow-sm border border-canvas-card-border' : 'text-mute hover:text-ink'}`}
          data-mode={mode}
        >
          {mode === 'cas' ? 'CAS' : mode.charAt(0).toUpperCase() + mode.slice(1)}
        </button>
      ))}
    </div>

    <!-- ===== MODE 1: STANDARD SCIENTIFIC ===== -->
    <div id="sci-standard-panel" class="grid grid-cols-1 lg:grid-cols-12 gap-4">
      <!-- Left Column: Main Calculator Layout (Display + Buttons) -->
      <div class="lg:col-span-7 space-y-3">
        <!-- Display Screen -->
        <div class="bg-canvas-card-soft border border-canvas-card-border rounded-xl p-3 flex flex-col items-end justify-between min-h-[80px] shadow-inner font-sans">
          <div id="sci-display-expr" class="w-full text-right text-ink text-sm font-medium overflow-x-auto whitespace-nowrap min-h-[20px]">&nbsp;</div>
          <div id="sci-display-result" class="w-full text-right text-ink text-3xl font-bold tracking-tighter overflow-x-auto whitespace-nowrap">0</div>
        </div>
        <!-- Function Buttons Grid (5 cols) -->
        <div class="grid grid-cols-5 gap-1.5">
          {[
            {k:'sin',l:'sin'},{k:'cos',l:'cos'},{k:'tan',l:'tan'},{k:'log',l:'log'},{k:'ln',l:'ln'},
            {k:'asin',l:'sin⁻¹'},{k:'acos',l:'cos⁻¹'},{k:'atan',l:'tan⁻¹'},{k:'sqrt',l:'√'},{k:'fact',l:'x!'},
            {k:'pi',l:'π'},{k:'e',l:'e'},{k:'pow',l:'xʸ'},{k:'open',l:'('},{k:'close',l:')'},
            {k:'tenPow',l:'10\u02e3'},{k:'ePow',l:'e\u02e3'},{k:'inv',l:'x\u207b\u00b9'},{k:'ncr',l:'nCr'},{k:'npr',l:'nPr'},
            {k:'rectpol',l:'R\u2194P'},{k:'dms',l:'DMS'},{k:'abs',l:'|x|'},{k:'ans',l:'Ans'},{k:'pct',l:'%'},
          ].map(btn => (
            <button class="sci-btn text-[10px] sm:text-xs font-bold bg-calc-btn border border-canvas-card-border text-body hover:bg-brand-primary hover:text-canvas rounded-lg py-1.5 sm:py-2.5 transition-all shadow-sm uppercase" data-sci={btn.k}>
              {btn.l}
            </button>
          ))}
        </div>
        <!-- Standard Numpad -->
        <div class="grid grid-cols-4 gap-1.5">
          <button class="sci-btn text-xs font-bold bg-calc-btn-soft border border-canvas-card-border text-link hover:bg-canvas-card-soft-2 rounded-lg py-2 sm:py-3 transition-all" data-sci="clear">C</button>
          <button class="sci-btn text-xs font-bold bg-calc-btn-soft border border-canvas-card-border text-mute hover:bg-canvas-card-soft-2 rounded-lg py-2 sm:py-3 transition-all" data-sci="back">⌫</button>
          <button class="sci-btn text-xs font-bold bg-calc-btn-soft border border-canvas-card-border text-mute hover:bg-canvas-card-soft-2 rounded-lg py-2 sm:py-3 transition-all" data-sci="mem">MR</button>
          <button class="sci-btn text-xs font-bold bg-calc-btn-soft border border-canvas-card-border text-link hover:bg-canvas-card-soft-2 rounded-lg py-2 sm:py-3 transition-all" data-sci="&#247;">&#247;</button>
          {['7','8','9','&#215;','4','5','6','-','1','2','3','+'].map(val => (
            <button class={`sci-btn text-lg font-bold ${['&#215;','-','+'].includes(val) ? 'bg-calc-btn-soft border-canvas-card-border text-link' : 'bg-calc-btn border-canvas-card-border text-ink'} border rounded-lg py-2.5 sm:py-3 transition-all shadow-sm hover:bg-canvas-card-soft-2`} data-sci={val === '&#215;' ? '×' : val}>{val === '&#215;' ? '×' : val}</button>
          ))}
          <button class="sci-btn text-lg font-bold bg-calc-btn border border-canvas-card-border text-ink rounded-lg py-2.5 sm:py-3 transition-all shadow-sm hover:bg-canvas-card-soft-2" data-sci="0">0</button>
          <button class="sci-btn text-lg font-bold bg-calc-btn border border-canvas-card-border text-ink rounded-lg py-2.5 sm:py-3 transition-all shadow-sm hover:bg-canvas-card-soft-2" data-sci=".">.</button>
          <button class="sci-btn col-span-2 text-sm font-bold bg-brand-primary hover:opacity-90 text-canvas rounded-lg py-2.5 sm:py-3 shadow-lg transition-all" data-sci="=">=</button>
        </div>
      </div>

      <!-- Right Column: Settings, Constants & Stats Toolbox -->
      <div class="lg:col-span-5 space-y-4">
        <div class="bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 sm:p-5 space-y-4 shadow-sm text-left">
          <h3 class="text-[11px] font-bold text-mute uppercase tracking-widest border-b border-canvas-card-border pb-3">Toolbox & Helpers</h3>
          <!-- Angle Mode Section -->
          <div class="flex items-center justify-between p-3 bg-canvas-card border border-canvas-card-border rounded-xl shadow-sm">
            <div class="flex flex-col">
              <span class="text-[9px] font-bold text-mute uppercase tracking-wider mb-0.5">Angle Unit</span>
              <span id="sci-angle-mode" class="font-mono text-xs font-black text-ink uppercase tracking-widest">DEG</span>
            </div>
            <button id="sci-angle-toggle" class="text-[10px] font-bold text-mute hover:text-ink px-4 py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">Cycle Mode</button>
          </div>
          <!-- Toggle Drawers -->
          <div class="grid grid-cols-2 gap-2">
            <button id="sci-toggle-const" class="text-[10px] font-bold text-mute hover:text-ink py-2.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">Constants</button>
            <button id="sci-toggle-stats" class="text-[10px] font-bold text-mute hover:text-ink py-2.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">Statistics</button>
          </div>
          <!-- Constants Drawer -->
          <div id="sci-const-drawer" class="hidden bg-canvas-card border border-canvas-card-border rounded-xl p-4 max-h-[220px] overflow-y-auto shadow-inner space-y-2">
            <p class="text-[9px] font-bold text-mute uppercase tracking-widest">Physical Constants (Click to insert)</p>
            <div class="grid grid-cols-1 gap-1.5" id="sci-const-list"></div>
          </div>
          <!-- Statistics Drawer -->
          <div id="sci-stats-drawer" class="hidden bg-canvas-card border border-canvas-card-border rounded-xl p-4 space-y-3 shadow-inner">
            <p class="text-[9px] font-bold text-mute uppercase tracking-widest">Statistics Analyzer</p>
            <input type="text" id="sci-stats-input" placeholder="Enter numbers (e.g. 12, 15, 23, 24)" class="w-full bg-canvas-card border border-canvas-card-border text-ink rounded-lg h-10 px-3 text-xs font-bold focus:outline-none focus:border-hairline-strong transition-all" />
            <div class="grid grid-cols-2 gap-1.5">
              {['Mean', 'StdDev', 'Variance', 'Count', 'Sum'].map(op => (
                <button class="sci-stats-btn text-[9px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all" data-stat={op.toLowerCase()}>{op}</button>
              ))}
            </div>
            <div id="sci-stats-result" class="text-xs font-mono font-bold text-link min-h-[16px] pt-2.5 border-t border-canvas-card-border"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== MODE 2: PROGRAMMABLE ===== -->
    <div id="sci-prog-panel" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-6">
      <!-- Left Column: Code Editor & Execution Console -->
      <div class="lg:col-span-8 space-y-4">
        <!-- Code Editor -->
        <div class="relative">
          <div class="absolute top-2 left-3 text-[8px] font-bold text-mute uppercase tracking-widest z-10 pointer-events-none select-none">Script Editor (Javascript Context)</div>
          <textarea id="prog-editor" class="w-full bg-canvas-card-soft border border-canvas-card-border text-ink rounded-xl p-4 pt-8 text-xs font-mono leading-6 focus:outline-none focus:border-hairline-strong transition-all resize-none shadow-inner" rows="7" placeholder="// Write your program here&#10;// Use print() to output results&#10;let sum = 0;&#10;for (let i = 1; i <= 10; i++) {&#10;  sum += i;&#10;}&amp;#10;print('Sum 1-10:', sum);"></textarea>
        </div>
        <!-- Run Controls Bar -->
        <div class="flex items-center gap-2 flex-wrap bg-canvas-card border border-canvas-card-border p-2 rounded-xl shadow-sm">
          <button id="prog-run" class="text-[10px] font-bold text-canvas bg-brand-primary hover:opacity-90 px-5 py-2 rounded-lg transition-all shadow-sm uppercase tracking-wider">▶ Run Code</button>
          <button id="prog-clear" class="text-[10px] font-bold text-mute hover:text-ink px-4 py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">Clear</button>
          <button id="prog-save" class="text-[10px] font-bold text-mute hover:text-ink px-4 py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">Save</button>
          <button id="prog-load" class="text-[10px] font-bold text-mute hover:text-ink px-4 py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">Load</button>
          <span class="text-[8px] text-mute">|</span>
          <button id="prog-record" class="text-[10px] font-bold text-mute hover:text-ink px-4 py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">⏺ Record Macro</button>
        </div>
        <!-- Output Console -->
        <div class="relative">
          <div class="absolute top-2 left-3 text-[8px] font-bold text-mute uppercase tracking-widest z-10 pointer-events-none select-none">Console Output</div>
          <div id="prog-output" class="w-full bg-canvas-card-soft border border-canvas-card-border text-ink rounded-xl p-4 pt-8 text-xs font-mono leading-6 min-h-[80px] max-h-[120px] overflow-y-auto whitespace-pre-wrap shadow-inner">Ready.</div>
        </div>
      </div>

      <!-- Right Column: Program Storage & Variable Watcher -->
      <div class="lg:col-span-4 space-y-4">
        <div class="bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 sm:p-5 space-y-4 shadow-sm text-left">
          <!-- Program Slots Selection -->
          <div>
            <h4 class="text-[9px] font-bold text-mute uppercase tracking-widest mb-2 border-b border-canvas-card-border pb-1">Program Memory Slots</h4>
            <div class="grid grid-cols-5 gap-1.5">
              {Array.from({length: 10}, (_, i) => (
                <button class="prog-slot-btn text-[10px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all text-center" data-slot={i.toString()}>{i}</button>
              ))}
            </div>
          </div>
          <!-- Variable Watcher Box -->
          <div>
            <h4 class="text-[9px] font-bold text-mute uppercase tracking-widest mb-2 border-b border-canvas-card-border pb-1">Live Variables Monitor</h4>
            <div id="prog-variables" class="w-full bg-canvas-card border border-canvas-card-border rounded-lg p-3 text-xs font-mono text-body min-h-[100px] max-h-[150px] overflow-y-auto shadow-inner leading-5">No variables.</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== MODE 3: GRAPHING ===== -->
    <div id="sci-graph-panel" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-6">
      <!-- Left Column: Graph Viewport Canvas & Zoom Controls -->
      <div class="lg:col-span-7 space-y-4">
        <!-- Interactive Canvas Frame -->
        <div class="relative bg-canvas-card border border-canvas-card-border rounded-xl overflow-hidden shadow-xl">
          <canvas id="graph-canvas" width="600" height="300" class="w-full cursor-crosshair" style="aspect-ratio:2/1;"></canvas>
          <div id="graph-trace-info" class="hidden absolute top-2 right-2 bg-canvas-card/90 border border-canvas-card-border rounded px-2 py-1 text-[10px] font-mono font-bold text-ink shadow-sm"></div>
        </div>
        <!-- Canvas Action Toolbar -->
        <div class="flex items-center gap-1.5 flex-wrap bg-canvas-card-soft border border-canvas-card-border p-2 rounded-xl shadow-sm">
          <button id="graph-zoom-in" class="text-[10px] font-bold text-mute hover:text-ink px-3 py-1.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all shadow-sm">Zoom +</button>
          <button id="graph-zoom-out" class="text-[10px] font-bold text-mute hover:text-ink px-3 py-1.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all shadow-sm">Zoom −</button>
          <button id="graph-reset" class="text-[10px] font-bold text-mute hover:text-ink px-3 py-1.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all shadow-sm">Reset View</button>
          <button id="graph-toggle-grid" class="text-[10px] font-bold text-mute hover:text-ink px-3 py-1.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all shadow-sm">Toggle Grid</button>
          <button id="graph-toggle-trace" class="text-[10px] font-bold text-mute hover:text-ink px-3 py-1.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all shadow-sm">Trace Coordinates</button>
        </div>
      </div>

      <!-- Right Column: Plot configuration & Analysis tools -->
      <div class="lg:col-span-5 space-y-4">
        <div class="bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 sm:p-5 space-y-4 shadow-sm text-left">
          <!-- Plot Mode Options -->
          <div class="flex items-center justify-between border-b border-canvas-card-border pb-3">
            <span class="text-[9px] font-bold text-mute uppercase tracking-wider">Coordinates</span>
            <div class="flex gap-1">
              {['cartesian', 'polar', 'parametric'].map(pm => (
                <button class={`graph-plotmode-btn text-[9px] font-bold px-2 py-1 rounded border border-canvas-card-border transition-all uppercase tracking-wider ${pm === 'cartesian' ? 'bg-calc-btn text-ink shadow-sm' : 'text-mute hover:text-ink bg-canvas-card-soft-2'}`} data-plotmode={pm}>
                  {pm === 'cartesian' ? 'y=f(x)' : pm === 'polar' ? 'r=f(θ)' : 'x(t),y(t)'}
                </button>
              ))}
            </div>
          </div>
          <!-- Functions Inputs -->
          <div class="space-y-2">
            <h4 class="text-[9px] font-bold text-mute uppercase tracking-widest border-b border-canvas-card-border pb-1">Functions List</h4>
            <div class="space-y-1.5" id="graph-fn-inputs">
              {[
                {idx: '0', color: '#0070f3', ph: 'e.g. sin(x)'},
                {idx: '1', color: '#ff0080', ph: 'e.g. x^2'},
                {idx: '2', color: '#50e3c2', ph: 'e.g. cos(x)'},
                {idx: '3', color: '#7928ca', ph: 'e.g. ln(x)'}
              ].map(f => (
                <div class="flex items-center gap-2">
                  <span class="w-2.5 h-2.5 rounded-full shrink-0" style={`background:${f.color}`}></span>
                  <span class="text-[9px] font-bold text-mute shrink-0">f{parseInt(f.idx)+1}</span>
                  <input type="text" class="graph-fn-input flex-1 bg-canvas-card border border-canvas-card-border text-ink rounded-md h-8 px-2 text-xs font-mono focus:outline-none focus:border-hairline-strong transition-all" data-fnidx={f.idx} placeholder={f.ph} />
                </div>
              ))}
            </div>
          </div>
          <!-- Calculus Analysis Toolbox -->
          <div>
            <h4 class="text-[9px] font-bold text-mute uppercase tracking-widest mb-2 border-b border-canvas-card-border pb-1">Calculus & Geometry</h4>
            <div class="grid grid-cols-2 gap-1.5">
              <button id="graph-find-zeros" class="text-[9px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all">Find Zeros</button>
              <button id="graph-find-extrema" class="text-[9px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all">Find Min/Max</button>
              <button id="graph-integral" class="text-[9px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all">∫ Area</button>
              <button id="graph-derivative" class="text-[9px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all">d/dx Derivative</button>
            </div>
          </div>
          <!-- Analysis Results Display Box -->
          <div id="graph-analysis" class="hidden bg-canvas-card border border-canvas-card-border rounded-xl p-3 text-xs font-mono text-body max-h-[90px] overflow-y-auto shadow-inner leading-5"></div>
          <!-- Table of Values and Scatter Point plots -->
          <div class="space-y-2">
            <button id="graph-toggle-table" class="w-full text-[9px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm">Toggle Value Table</button>
            <div id="graph-table-container" class="hidden bg-canvas-card border border-canvas-card-border rounded-xl p-3 max-h-[160px] overflow-auto shadow-inner">
              <table class="w-full text-[10px] font-mono" id="graph-table"><thead></thead><tbody></tbody></table>
            </div>
            <details class="group border border-canvas-card-border rounded-xl p-3 bg-canvas-card">
              <summary class="text-[9px] font-bold text-mute hover:text-ink cursor-pointer uppercase tracking-wider">Scatter Data Overlay</summary>
              <div class="mt-2 space-y-2">
                <textarea id="graph-scatter-input" class="w-full bg-canvas-card-soft-2 border border-canvas-card-border text-ink rounded-lg p-2 text-[10px] font-mono leading-4 focus:outline-none resize-none shadow-inner" rows="4" placeholder="Paste x,y data (one point per line)&#10;1, 2&#10;3, 5&#10;4, 7"></textarea>
                <button id="graph-scatter-plot" class="text-[9px] font-bold text-mute hover:text-ink px-3 py-1.5 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all shadow-sm">Plot Points</button>
              </div>
            </details>
          </div>
        </div>
      </div>
    </div>

    <!-- ===== MODE 4: CAS (Computer Algebra System) ===== -->
    <div id="sci-cas-panel" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-6">
      <!-- Left Column: CAS Input, Output & History -->
      <div class="lg:col-span-7 space-y-4">
        <!-- CAS Result Screen -->
        <div class="bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 shadow-inner min-h-[100px] flex flex-col justify-between">
          <div id="cas-display-label" class="text-[9px] font-bold text-mute uppercase tracking-widest mb-1">Result</div>
          <div id="cas-display-result" class="text-xl sm:text-2xl font-bold text-link tracking-tight font-mono overflow-x-auto whitespace-nowrap">Ready</div>
        </div>
        <!-- CAS Input -->
        <div class="relative">
          <input type="text" id="cas-input" class="w-full bg-canvas-card-soft-2 border border-canvas-card-border text-ink rounded-xl h-12 px-4 text-sm font-mono font-bold focus:outline-none focus:border-hairline-strong focus:ring-4 focus:ring-canvas-soft transition-all shadow-inner" placeholder="Enter algebraic expression, e.g. x^2 + 2*x + 1" />
        </div>
        <!-- CAS History Accordion -->
        <details class="group bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 shadow-sm">
          <summary class="text-[9px] font-bold text-mute hover:text-ink cursor-pointer uppercase tracking-wider flex items-center gap-2">
            <svg class="w-3 h-3 transition-transform group-open:rotate-90" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M9 18l6-6-6-6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Computation History Log
          </summary>
          <div id="cas-history" class="mt-3 bg-canvas-card border border-canvas-card-border rounded-lg p-3 max-h-[220px] overflow-y-auto text-xs font-mono text-body space-y-2 shadow-inner">
            <div class="text-mute">No history yet.</div>
          </div>
        </details>
      </div>

      <!-- Right Column: Operations toolbar & settings -->
      <div class="lg:col-span-5 space-y-4">
        <div class="bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 sm:p-5 space-y-4 shadow-sm text-left">
          <h4 class="text-[9px] font-bold text-mute uppercase tracking-widest pb-2 border-b border-canvas-card-border">Symbolic Algebra Toolkit</h4>
          <!-- Operations Grid (3 columns for cleaner larger layout) -->
          <div class="grid grid-cols-3 gap-1.5">
            {[
              {k:'cas-eval',l:'Evaluate'},{k:'cas-simplify',l:'Simplify'},{k:'cas-factor',l:'Factor'},{k:'cas-expand',l:'Expand'},
              {k:'cas-derivative',l:'d/dx'},{k:'cas-integrate',l:'∫dx'},
              {k:'cas-solve',l:'Solve'},{k:'cas-taylor',l:'Taylor'},
              {k:'cas-limit',l:'Limit'},{k:'cas-det',l:'det(M)'},
              {k:'cas-inv-matrix',l:'M⁻¹'},{k:'cas-clear',l:'Clear'}
            ].map(op => (
              <button class="cas-op-btn text-[9px] font-bold text-mute hover:text-ink py-2 rounded-lg border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all uppercase tracking-wider shadow-sm" data-cas-op={op.k}>{op.l}</button>
            ))}
          </div>
          <!-- Variable and bounds config -->
          <div class="grid grid-cols-2 gap-2 bg-canvas-card p-3 rounded-xl border border-canvas-card-border shadow-sm">
            <div class="flex flex-col gap-1">
              <label class="text-[9px] font-bold text-mute uppercase tracking-wider">Target Variable</label>
              <input type="text" id="cas-variable" value="x" class="w-full bg-canvas-card-soft-2 border border-canvas-card-border text-ink rounded-lg h-8 px-2 text-xs font-mono font-bold focus:outline-none" />
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-[9px] font-bold text-mute uppercase tracking-wider">Taylor Order</label>
              <input type="number" id="cas-taylor-order" value="5" min="1" max="20" class="w-full bg-canvas-card-soft-2 border border-canvas-card-border text-ink rounded-lg h-8 px-2 text-xs font-mono font-bold focus:outline-none" />
            </div>
            <div class="flex flex-col gap-1">
              <label class="text-[9px] font-bold text-mute uppercase tracking-wider">Lower Bound (From)</label>
              <input type="number" id="cas-bound-a" value="0" class="w-full bg-canvas-card-soft-2 border border-canvas-card-border text-ink rounded-lg h-8 px-2 text-xs font-mono font-bold focus:outline-none" />
