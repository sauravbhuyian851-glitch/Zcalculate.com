        const ctrl = new mod.ScientificCalculatorController();
        const { StandardEngine, ProgrammableEngine, GraphingEngine, CASEngine, PHYSICAL_CONSTANTS, mean, stddev, variance } = mod;

        const activeMode = slug === 'programmable-calculator' ? 'programmable' :
                           slug === 'graphing-calculator' ? 'graphing' :
                           slug === 'cas-calculator' ? 'cas' : 'standard';

        ctrl.switchMode(activeMode);

        if (activeMode === 'graphing') {
          const canvas = document.getElementById('graph-canvas') as HTMLCanvasElement;
          if (canvas) {
            setTimeout(() => {
              if (!ctrl.graphing.canvas) ctrl.graphing.init(canvas);
            }, 50);
          }
        }

        let expr = '';
        const resDisp = document.getElementById('sci-display-result');
        const exprDisp = document.getElementById('sci-display-expr');
        const angleModeEl = document.getElementById('sci-angle-mode');
        const panels = {
          standard: document.getElementById('sci-standard-panel'),
          programmable: document.getElementById('sci-prog-panel'),
          graphing: document.getElementById('sci-graph-panel'),
          cas: document.getElementById('sci-cas-panel'),
        };

        const appendSciVal = (val: string) => {
          expr += val;
          if (exprDisp) exprDisp.textContent = expr;
        };

        const backspaceSci = () => {
          const funcMatch = ['asin(', 'acos(', 'atan(', 'sin(', 'cos(', 'tan(', 'log(', 'ln(', 'sqrt(', 'abs(', 'tenPow(', 'ePow(', 'inv(', 'nCr(', 'nPr('].find(f => expr.endsWith(f));
          expr = funcMatch ? expr.substring(0, expr.length - funcMatch.length) : expr.substring(0, expr.length - 1);
          if (exprDisp) exprDisp.textContent = expr || '\u00A0';
          if (!expr && resDisp) resDisp.textContent = '0';
        };

        const calculateSci = () => {
          const result = ctrl.standard.evaluate(expr);
          const formatted = ctrl.standard.formatResult(result);
          if (resDisp) resDisp.textContent = formatted;
          
          if ((window as any).zcalculate_saveToHistory) {
            const activeTitle = document.querySelector('h1')?.textContent?.replace(/\.$/, '') || 'Scientific Calculator';
            (window as any).zcalculate_saveToHistory(activeTitle, expr, formatted);
          }
          
          expr = !isNaN(result) ? result.toString() : '';
        };

        const handleSciKeyDown = (e: KeyboardEvent) => {
          const activeEl = document.activeElement;
          if (activeEl && (activeEl.tagName === 'INPUT' || activeEl.tagName === 'TEXTAREA' || activeEl.tagName === 'SELECT')) {
            if (e.key === 'Enter') {
              e.preventDefault();
              calculateSci();
            }
            return;
          }

          const key = e.key;
          if (/[0-9\.\(\)]/.test(key)) {
            appendSciVal(key);
          } else if (key === '+') {
            appendSciVal('+');
          } else if (key === '-') {
            appendSciVal('-');
          } else if (key === '*' || key === 'x' || key === 'X') {
            appendSciVal('×');
          } else if (key === '/') {
            appendSciVal('÷');
          } else if (key === '^') {
            appendSciVal('^');
          } else if (key === 'Enter' || key === '=') {
            e.preventDefault();
            calculateSci();
          } else if (key === 'Backspace') {
            e.preventDefault();
            backspaceSci();
          } else if (key === 'Escape' || key === 'c' || key === 'C') {
            expr = '';
            if (resDisp) resDisp.textContent = '0';
            if (exprDisp) exprDisp.textContent = '\u00A0';
          }
        };

        if ((window as any)._sciKeyDownHandler) {
          document.removeEventListener('keydown', (window as any)._sciKeyDownHandler);
        }
        (window as any)._sciKeyDownHandler = handleSciKeyDown;
        document.addEventListener('keydown', handleSciKeyDown);

        // Fullscreen API implementation for scientific calculator container
        const sciContainer = document.getElementById('sci-calc-root');
        const sciFullscreenBtn = document.getElementById('sci-fullscreen');
        const applySciFullscreenLayout = () => {
          const isCurrentlyFullscreen = document.fullscreenElement === sciContainer;
          if (isCurrentlyFullscreen) {
            if (sciFullscreenBtn) {
              sciFullscreenBtn.innerHTML = `
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M4 14h6v6m10-6h-6v6M4 10h6V4m10 6h-6V4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Exit
              `;
            }
          } else {
            if (sciFullscreenBtn) {
              sciFullscreenBtn.innerHTML = `
                <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Full
              `;
            }
          }
        };

        if (sciFullscreenBtn && sciContainer) {
          sciFullscreenBtn.onclick = (e) => {
            e.preventDefault();
            e.stopPropagation();
            if (!document.fullscreenElement) {
              sciContainer.requestFullscreen().catch(err => {
                console.error(`Fullscreen request failed: ${err.message}`);
              });
            } else {
              document.exitFullscreen();
            }
          };
          document.addEventListener('fullscreenchange', applySciFullscreenLayout);
          applySciFullscreenLayout();
        }



        // ===== STANDARD MODE =====
        // Angle mode cycling (DEG -> RAD -> GRAD -> DEG)
        const angleToggle = document.getElementById('sci-angle-toggle');
        if (angleToggle && angleModeEl) {
          angleToggle.onclick = () => {
            const modes: Array<'DEG'|'RAD'|'GRAD'> = ['DEG', 'RAD', 'GRAD'];
            const idx = modes.indexOf(ctrl.standard.angleMode);
            ctrl.standard.angleMode = modes[(idx + 1) % 3];
            angleModeEl.textContent = ctrl.standard.angleMode;
          };
        }

        // Constants drawer
        const constToggle = document.getElementById('sci-toggle-const');
        const constDrawer = document.getElementById('sci-const-drawer');
        const constList = document.getElementById('sci-const-list');
        if (constToggle && constDrawer && constList) {
          // Populate constants
          constList.innerHTML = Object.entries(PHYSICAL_CONSTANTS).map(([key, c]) =>
            `<button class="sci-const-item text-left text-[9px] font-mono text-body hover:text-ink px-2 py-1 rounded border border-canvas-card-border bg-calc-btn hover:bg-canvas-card-soft-2 transition-all" data-const-val="${c.value}" title="${c.label}: ${c.value} ${c.unit}"><strong>${key}</strong> <span class="text-mute">${c.value.toExponential(2)}</span></button>`
          ).join('');
          constToggle.onclick = () => constDrawer.classList.toggle('hidden');
          constList.querySelectorAll('.sci-const-item').forEach(btn => {
            (btn as HTMLButtonElement).onclick = () => {
              const val = btn.getAttribute('data-const-val') || '';
              expr += val;
              if (exprDisp) exprDisp.textContent = expr;
            };
          });
        }

        // Statistics drawer
        const statsToggle = document.getElementById('sci-toggle-stats');
        const statsDrawer = document.getElementById('sci-stats-drawer');
        if (statsToggle && statsDrawer) {
          statsToggle.onclick = () => statsDrawer.classList.toggle('hidden');
        }
        document.querySelectorAll('.sci-stats-btn').forEach(btn => {
          (btn as HTMLButtonElement).onclick = () => {
            const op = btn.getAttribute('data-stat');
            const input = (document.getElementById('sci-stats-input') as HTMLInputElement)?.value || '';
            const data = input.split(',').map(s => parseFloat(s.trim())).filter(n => !isNaN(n));
            const resultEl = document.getElementById('sci-stats-result');
            if (data.length === 0) { if (resultEl) resultEl.textContent = 'No valid data'; return; }
            let result = '';
            switch (op) {
              case 'mean': result = `Mean: ${mean(data).toFixed(6)}`; break;
              case 'stddev': result = `Std Dev: ${stddev(data).toFixed(6)}`; break;
              case 'variance': result = `Variance: ${variance(data).toFixed(6)}`; break;
              case 'count': result = `Count: ${data.length}`; break;
              case 'sum': result = `Sum: ${data.reduce((a, b) => a + b, 0).toFixed(6)}`; break;
            }
            if (resultEl) resultEl.textContent = result;
          };
        });

        // Standard scientific buttons
        document.querySelectorAll('.sci-btn').forEach(b => {
          (b as HTMLButtonElement).onclick = () => {
            const v = b.getAttribute('data-sci');
            if (!v) return;
            // Record macro if recording
            ctrl.programmable.recordKeystroke(v);

            if (v === '=') {
              calculateSci();
            }
            else if (v === 'clear') {
              expr = '';
              if (resDisp) resDisp.textContent = '0';
              if (exprDisp) exprDisp.textContent = '\u00A0';
            }
            else if (v === 'back') {
              backspaceSci();
            }
            else if (v === 'mem') {
              expr += ctrl.standard.memory.toString();
              if (exprDisp) exprDisp.textContent = expr;
            }
            else {
              let insert = v;
              const fnMap: Record<string, string> = {
                'sin': 'sin(', 'cos': 'cos(', 'tan': 'tan(',
                'asin': 'asin(', 'acos': 'acos(', 'atan': 'atan(',
                'log': 'log(', 'ln': 'ln(', 'sqrt': 'sqrt(', 'abs': 'abs(',
                'tenPow': 'tenPow(', 'ePow': 'ePow(', 'inv': 'inv(',
                'ncr': 'nCr(', 'npr': 'nPr(',
                'fact': '!', 'pi': 'π', 'pow': '^',
                'open': '(', 'close': ')',
                'e': 'e', 'pct': '%', 'ans': 'Ans',
              };
              if (fnMap[v]) insert = fnMap[v];
              else if (v === 'rectpol') {
                // Insert dialog placeholder
                const x = prompt('Enter X (or R):');
                const y = prompt('Enter Y (or θ):');
                if (x && y) {
                  const xn = parseFloat(x), yn = parseFloat(y);
                  const result = mod.rectToPol(xn, yn);
                  if (resDisp) resDisp.textContent = `r=${result.r.toFixed(6)}, θ=${(result.theta * 180 / Math.PI).toFixed(4)}°`;
                  if (exprDisp) exprDisp.textContent = `Rect→Pol(${x}, ${y})`;
                }
                return;
              }
              else if (v === 'dms') {
                const dec = prompt('Enter decimal degrees:');
                if (dec) {
                  const result = mod.decToDms(parseFloat(dec));
                  if (resDisp) resDisp.textContent = `${result.deg}° ${result.min}' ${result.sec}"`;
                  if (exprDisp) exprDisp.textContent = `Dec→DMS(${dec})`;
                }
                return;
              }
              expr += insert;
              if (exprDisp) exprDisp.textContent = expr;
            }
          };
        });

        // ===== PROGRAMMABLE MODE =====
        const progEditor = document.getElementById('prog-editor') as HTMLTextAreaElement;
        const progOutput = document.getElementById('prog-output');
        const progVars = document.getElementById('prog-variables');
        let currentProgSlot = 0;

        // Run button
        const progRun = document.getElementById('prog-run');
        if (progRun) {
          progRun.onclick = () => {
            const code = progEditor?.value || '';
            if (!code.trim()) return;
            if (progOutput) progOutput.textContent = 'Running...\n';
            setTimeout(() => {
              const result = ctrl.programmable.run(code, ctrl.standard);
              if (progOutput) {
                const outStr = result.output.length > 0 ? result.output.join('\n') : '(No output)';
                progOutput.textContent = outStr;
                if (result.error) progOutput.textContent += `\n\nError: ${result.error}`;
                
                if ((window as any).zcalculate_saveToHistory) {
                  (window as any).zcalculate_saveToHistory('Programmable Calculator', code, result.error ? `Error: ${result.error}` : (result.output.length > 0 ? result.output.join(', ') : 'Success'));
                }
              }
              if (progVars) {
                const entries = Object.entries(result.variables);
                progVars.textContent = entries.length > 0 ? entries.map(([k, v]) => `${k} = ${v}`).join('\n') : 'No variables.';
              }
            }, 50);
          };
        }

        // Clear
        const progClear = document.getElementById('prog-clear');
        if (progClear) progClear.onclick = () => {
          if (progEditor) progEditor.value = '';
          if (progOutput) progOutput.textContent = 'Ready.';
          if (progVars) progVars.textContent = 'No variables.';
        };

        // Save / Load
        document.querySelectorAll('.prog-slot-btn').forEach(btn => {
          (btn as HTMLButtonElement).onclick = () => {
            currentProgSlot = parseInt(btn.getAttribute('data-slot') || '0');
            document.querySelectorAll('.prog-slot-btn').forEach(b => {
              (b as HTMLElement).className = (b as HTMLElement).className.replace(/text-ink bg-calc-btn-soft/g, 'text-mute');
            });
            (btn as HTMLElement).className = (btn as HTMLElement).className.replace(/text-mute/g, 'text-ink bg-calc-btn-soft');
          };
        });

        const progSave = document.getElementById('prog-save');
        if (progSave) progSave.onclick = () => {
          const code = progEditor?.value || '';
          const name = prompt('Program name:', `Program ${currentProgSlot}`) || `Program ${currentProgSlot}`;
          ctrl.programmable.saveProgram(currentProgSlot, name, code);
          if (progOutput) progOutput.textContent = `Saved to slot ${currentProgSlot}: "${name}"`;
        };

        const progLoad = document.getElementById('prog-load');
        if (progLoad) progLoad.onclick = () => {
          const prog = ctrl.programmable.getProgram(currentProgSlot);
          if (progEditor) progEditor.value = prog.code;
          if (progOutput) progOutput.textContent = `Loaded slot ${currentProgSlot}: "${prog.name}"`;
        };

        // Macro recorder
        const progRecord = document.getElementById('prog-record');
        if (progRecord) {
          progRecord.onclick = () => {
            if (ctrl.programmable.isRecording) {
              const macroCode = ctrl.programmable.stopRecording();
              if (progEditor) progEditor.value = macroCode;
              progRecord.textContent = '⏺ Record Macro';
              if (progOutput) progOutput.textContent = 'Macro recorded. Switch to Standard mode to test.';
            } else {
              ctrl.programmable.startRecording();
              progRecord.textContent = '⏹ Stop Recording';
              if (progOutput) progOutput.textContent = 'Recording... Use Standard mode buttons, then click Stop.';
            }
          };
        }

        // ===== GRAPHING MODE =====
        const graphCanvas = document.getElementById('graph-canvas') as HTMLCanvasElement;

        // Function input handlers
        document.querySelectorAll('.graph-fn-input').forEach(input => {
          (input as HTMLInputElement).oninput = () => {
            const idx = parseInt(input.getAttribute('data-fnidx') || '0');
            ctrl.graphing.functions[idx].expr = (input as HTMLInputElement).value;
            ctrl.graphing.render();
          };
        });

        // Plot mode selector
        document.querySelectorAll('.graph-plotmode-btn').forEach(btn => {
          (btn as HTMLButtonElement).onclick = () => {
            const mode = btn.getAttribute('data-plotmode') as any;
            ctrl.graphing.plotMode = mode;
            document.querySelectorAll('.graph-plotmode-btn').forEach(b => {
              (b as HTMLElement).className = (b as HTMLElement).className.replace(/bg-calc-btn text-ink shadow-sm/g, 'text-mute hover:text-ink bg-canvas-card-soft-2');
            });
            (btn as HTMLElement).className = (btn as HTMLElement).className.replace(/text-mute hover:text-ink bg-canvas-card-soft-2/g, 'bg-calc-btn text-ink shadow-sm');
            ctrl.graphing.render();
          };
        });

        // Zoom / Pan / Reset / Grid / Trace
        document.getElementById('graph-zoom-in')?.addEventListener('click', () => ctrl.graphing.zoom(0.7));
        document.getElementById('graph-zoom-out')?.addEventListener('click', () => ctrl.graphing.zoom(1.4));
        document.getElementById('graph-reset')?.addEventListener('click', () => ctrl.graphing.resetView());
        document.getElementById('graph-toggle-grid')?.addEventListener('click', () => { ctrl.graphing.showGrid = !ctrl.graphing.showGrid; ctrl.graphing.render(); });

        const traceBtn = document.getElementById('graph-toggle-trace');
        if (traceBtn) {
          traceBtn.onclick = () => {
            ctrl.graphing.traceMode = !ctrl.graphing.traceMode;
            traceBtn.classList.toggle('text-link', ctrl.graphing.traceMode);
            if (!ctrl.graphing.traceMode) {
              ctrl.graphing.tracePoint = null;
              ctrl.graphing.render();
            }
          };
        }

        // Canvas mouse interaction
        if (graphCanvas) {
          let isPanning = false;
          let panStartX = 0, panStartY = 0;

          graphCanvas.onmousemove = (e) => {
            if (isPanning) {
              const dx = (e.movementX / graphCanvas.width);
              const dy = (e.movementY / graphCanvas.height);
              ctrl.graphing.pan(dx, dy);
            } else if (ctrl.graphing.traceMode) {
              const rect = graphCanvas.getBoundingClientRect();
              const scaleX = graphCanvas.width / rect.width;
              const scaleY = graphCanvas.height / rect.height;
              const mx = (e.clientX - rect.left) * scaleX;
              const my = (e.clientY - rect.top) * scaleY;
              const mathX = ctrl.graphing.toMathX(mx);
              const mathY = ctrl.graphing.toMathY(my);
              ctrl.graphing.tracePoint = { x: mathX, y: mathY };
              // Snap to first visible function
              const fn = ctrl.graphing.functions.find(f => f.expr && f.visible);
              if (fn) {
                try {
                  const mathjs = (window as any).math;
                  if (mathjs) {
                    const fy = mathjs.evaluate(fn.expr, { x: mathX, pi: Math.PI, e: Math.E });
                    if (typeof fy === 'number' && isFinite(fy)) {
                      ctrl.graphing.tracePoint = { x: mathX, y: fy };
                    }
                  }
                } catch {}
              }
              ctrl.graphing.render();
              const traceInfo = document.getElementById('graph-trace-info');
              if (traceInfo && ctrl.graphing.tracePoint) {
                traceInfo.classList.remove('hidden');
                traceInfo.textContent = `(${ctrl.graphing.tracePoint.x.toFixed(4)}, ${ctrl.graphing.tracePoint.y.toFixed(4)})`;
              }
            }
          };

          graphCanvas.onmousedown = (e) => { if (e.button === 0 && !ctrl.graphing.traceMode) { isPanning = true; } };
          graphCanvas.onmouseup = () => { isPanning = false; };
          graphCanvas.onmouseleave = () => { isPanning = false; };
          graphCanvas.onwheel = (e) => { e.preventDefault(); ctrl.graphing.zoom(e.deltaY > 0 ? 1.15 : 0.87); };
        }

        // Analysis tools
        const analysisEl = document.getElementById('graph-analysis');
        const showAnalysis = (text: string) => {
          if (analysisEl) { analysisEl.classList.remove('hidden'); analysisEl.textContent = text; }
        };

        document.getElementById('graph-find-zeros')?.addEventListener('click', () => {
          const zeros = ctrl.graphing.findZeros(0);
          showAnalysis(zeros.length > 0 ? `Zeros of f₁: x = ${zeros.join(', ')}` : 'No zeros found in current view.');
        });
        document.getElementById('graph-find-extrema')?.addEventListener('click', () => {
          const ext = ctrl.graphing.findExtrema(0);
          let text = '';
          if (ext.minima.length > 0) text += `Minima: ${ext.minima.map(p => `(${p.x}, ${p.y})`).join(', ')}\n`;
          if (ext.maxima.length > 0) text += `Maxima: ${ext.maxima.map(p => `(${p.x}, ${p.y})`).join(', ')}`;
          showAnalysis(text || 'No extrema found in current view.');
        });
        document.getElementById('graph-integral')?.addEventListener('click', () => {
          const a = parseFloat(prompt('Lower bound (a):', String(ctrl.graphing.xMin)) || '');
          const b = parseFloat(prompt('Upper bound (b):', String(ctrl.graphing.xMax)) || '');
          if (!isNaN(a) && !isNaN(b)) {
            const result = ctrl.graphing.numericalIntegral(0, a, b);
            showAnalysis(`∫f₁(x)dx from ${a} to ${b} ≈ ${result.toFixed(8)}`);
          }
        });
        document.getElementById('graph-derivative')?.addEventListener('click', () => {
          const x0 = parseFloat(prompt('Evaluate derivative at x =', '0') || '');
          if (!isNaN(x0)) {
            const result = ctrl.graphing.numericalDerivative(0, x0);
            showAnalysis(`f₁'(${x0}) ≈ ${result.toFixed(8)}`);
          }
        });

        // Table view
        document.getElementById('graph-toggle-table')?.addEventListener('click', () => {
          const container = document.getElementById('graph-table-container');
          if (container) {
            container.classList.toggle('hidden');
            if (!container.classList.contains('hidden')) {
              const table = ctrl.graphing.generateTable();
              const graphTable = document.getElementById('graph-table');
              if (graphTable && table.length > 0) {
                const activeFns = ctrl.graphing.functions.filter(f => f.expr && f.visible);
                let html = '<thead><tr class="text-mute border-b border-canvas-card-border"><th class="pb-2 pr-3">x</th>';
                activeFns.forEach((_, i) => { html += `<th class="pb-2 pr-3">f${i+1}(x)</th>`; });
                html += '</tr></thead><tbody>';
                table.forEach(row => {
                  html += `<tr class="border-b border-canvas-card-border/30"><td class="py-1 pr-3 text-mute">${row.x}</td>`;
                  row.values.forEach(v => { html += `<td class="py-1 pr-3 text-ink font-bold">${isNaN(v) ? '-' : v.toFixed(4)}</td>`; });
                  html += '</tr>';
                });
                graphTable.innerHTML = html + '</tbody>';
              }
            }
          }
        });

        // Scatter plot
        document.getElementById('graph-scatter-plot')?.addEventListener('click', () => {
          const input = (document.getElementById('graph-scatter-input') as HTMLTextAreaElement)?.value || '';
          ctrl.graphing.parseScatterData(input);
        });

        // ===== CAS MODE =====
        const casInput = document.getElementById('cas-input') as HTMLInputElement;
        const casResult = document.getElementById('cas-display-result');
        const casLabel = document.getElementById('cas-display-label');
        const casHistory = document.getElementById('cas-history');

        const updateCASResult = (label: string, result: string) => {
          if (casResult) casResult.textContent = result;
          if (casLabel) casLabel.textContent = label;
          if (casHistory) {
            const entries = ctrl.cas.history.map(h => `<div><span class="text-mute">▸ ${h.input}</span><br/><span class="text-ink font-bold">${h.output}</span></div>`).join('');
            casHistory.innerHTML = entries || '<div class="text-mute">No history yet.</div>';
          }
        };

        // CAS insert buttons
        document.querySelectorAll('.cas-insert-btn').forEach(btn => {
          (btn as HTMLButtonElement).onclick = () => {
            const val = btn.getAttribute('data-insert') || '';
            if (casInput) {
              const pos = casInput.selectionStart || casInput.value.length;
              casInput.value = casInput.value.slice(0, pos) + val + casInput.value.slice(pos);
              casInput.focus();
            }
          };
        });

        // CAS Enter key
        if (casInput) {
          casInput.onkeydown = (e) => {
            if (e.key === 'Enter') {
              const val = casInput.value;
              const result = ctrl.cas.evaluate(val);
              updateCASResult('Result', result);
              if ((window as any).zcalculate_saveToHistory) {
                (window as any).zcalculate_saveToHistory('CAS Calculator', val, result);
              }
            }
          };
        }

        // CAS operation buttons
        document.querySelectorAll('.cas-op-btn').forEach(btn => {
          (btn as HTMLButtonElement).onclick = () => {
            const op = btn.getAttribute('data-cas-op');
            const input = casInput?.value || '';
            const variable = (document.getElementById('cas-variable') as HTMLInputElement)?.value || 'x';
            const a = parseFloat((document.getElementById('cas-bound-a') as HTMLInputElement)?.value || '0');
            const b = parseFloat((document.getElementById('cas-bound-b') as HTMLInputElement)?.value || '1');
            const order = parseInt((document.getElementById('cas-taylor-order') as HTMLInputElement)?.value || '5');

            let result = '';
            let label = 'Result';
            switch (op) {
              case 'cas-eval': result = ctrl.cas.evaluate(input); label = 'Evaluate'; break;
              case 'cas-simplify': result = ctrl.cas.simplify(input); label = 'Simplify'; break;
              case 'cas-factor': result = ctrl.cas.factor(input); label = 'Factor'; break;
              case 'cas-expand': result = ctrl.cas.expand(input); label = 'Expand'; break;
              case 'cas-derivative': result = ctrl.cas.derivative(input, variable); label = `d/d${variable}`; break;
              case 'cas-integrate': result = ctrl.cas.integrate(input, variable, a, b); label = `∫d${variable} [${a},${b}]`; break;
              case 'cas-solve': result = ctrl.cas.solve(input, variable); label = 'Solve'; break;
              case 'cas-taylor': result = ctrl.cas.taylor(input, variable, a, order); label = `Taylor (order ${order})`; break;
              case 'cas-limit': result = ctrl.cas.limit(input, variable, a); label = `Limit as ${variable}→${a}`; break;
              case 'cas-det':
                try {
                  const mathjs = (window as any).math;
                  if (mathjs) { result = mathjs.det(mathjs.evaluate(input)).toString(); } else result = 'math.js not loaded';
                } catch (e: any) { result = `Error: ${e.message}`; }
                label = 'Determinant';
                break;
              case 'cas-inv-matrix':
                try {
                  const mathjs = (window as any).math;
                  if (mathjs) { result = mathjs.format(mathjs.inv(mathjs.evaluate(input)), { precision: 6 }); } else result = 'math.js not loaded';
                } catch (e: any) { result = `Error: ${e.message}`; }
                label = 'Inverse Matrix';
                break;
              case 'cas-clear':
                if (casInput) casInput.value = '';
                result = 'Ready';
                label = 'Result';
                ctrl.cas.variables = {};
                break;
            }
            updateCASResult(label, result);
            if (op !== 'cas-clear' && (window as any).zcalculate_saveToHistory) {
              (window as any).zcalculate_saveToHistory('CAS Calculator', `${label}: ${input}`, result);
            }
          };
        });
      });
    }

    // --- Fraction Calculator ---
    if (slug === 'fraction-calculator') {
      const calcBtn = document.getElementById('frac-calculate');
      if (calcBtn) {
        calcBtn.onclick = () => {
          const n1 = parseInt((document.getElementById('frac-num1') as HTMLInputElement)?.value) || 0;
          const d1 = parseInt((document.getElementById('frac-den1') as HTMLInputElement)?.value) || 1;
          const n2 = parseInt((document.getElementById('frac-num2') as HTMLInputElement)?.value) || 0;
          const d2 = parseInt((document.getElementById('frac-den2') as HTMLInputElement)?.value) || 1;
          const op = (document.getElementById('frac-operator') as HTMLSelectElement)?.value || '+';

          let rn = 0, rd = 1;
          if (op === '+') { rn = n1 * d2 + n2 * d1; rd = d1 * d2; }
          else if (op === '-') { rn = n1 * d2 - n2 * d1; rd = d1 * d2; }
          else if (op === '*') { rn = n1 * n2; rd = d1 * d2; }
          else if (op === '/') { rn = n1 * d2; rd = d1 * n2; }

          // GCD for reduction
          function gcd(a: number, b: number): number { a = Math.abs(a); b = Math.abs(b); while (b) { [a, b] = [b, a % b]; } return a; }
          const g = gcd(rn, rd);
          const frn = rn / g;
          const frd = rd / g;

          // Handle negative denominator
          const finalNum = frd < 0 ? -frn : frn;
          const finalDen = Math.abs(frd);

          const resultEl = document.getElementById('frac-result');
          const decimalEl = document.getElementById('frac-decimal');
          if (resultEl) resultEl.textContent = finalDen === 1 ? `${finalNum}` : `${finalNum}/${finalDen}`;
          if (decimalEl) decimalEl.textContent = (finalNum / finalDen).toFixed(6);

          // Show steps
          const stepsContainer = document.getElementById('frac-steps-container');
          const step1 = document.getElementById('frac-step1');
          const step2 = document.getElementById('frac-step2');
          const step3 = document.getElementById('frac-step3');
          if (stepsContainer) stepsContainer.classList.remove('hidden');
          if (step1) step1.textContent = `Step 1: ${n1}/${d1} ${op} ${n2}/${d2}`;
          if (step2) step2.textContent = `Step 2: = ${rn}/${rd}`;
          if (step3) step3.textContent = `Step 3: Reduced by GCD(${g}) = ${finalNum}/${finalDen}`;
        };
      }
    }

    // --- Triangle Calculator ---
    if (slug === 'triangle-calculator') {
      const triCalcBtn = document.getElementById('tri-calculate');
      if (triCalcBtn) {
        triCalcBtn.onclick = () => {
          const a = parseFloat((document.getElementById('tri-side-a') as HTMLInputElement)?.value) || 0;
          const b = parseFloat((document.getElementById('tri-side-b') as HTMLInputElement)?.value) || 0;
          const c = parseFloat((document.getElementById('tri-side-c') as HTMLInputElement)?.value) || 0;

          // Check triangle inequality
          if (a + b <= c || a + c <= b || b + c <= a || a <= 0 || b <= 0 || c <= 0) {
            const anglesEl = document.getElementById('tri-angles');
            if (anglesEl) anglesEl.textContent = 'Invalid triangle';
            return;
          }

          // Law of cosines for angles
          const angleA = Math.acos((b * b + c * c - a * a) / (2 * b * c)) * (180 / Math.PI);
          const angleB = Math.acos((a * a + c * c - b * b) / (2 * a * c)) * (180 / Math.PI);
          const angleC = 180 - angleA - angleB;

          // Heron's formula for area
          const s = (a + b + c) / 2;
          const area = Math.sqrt(s * (s - a) * (s - b) * (s - c));
          const perimeter = a + b + c;

          // Determine triangle type
          let triType = 'Scalene';
          if (a === b && b === c) triType = 'Equilateral';
          else if (a === b || b === c || a === c) triType = 'Isosceles';

          const anglesEl = document.getElementById('tri-angles');
          const areaEl = document.getElementById('tri-area');
          const perimeterEl = document.getElementById('tri-perimeter');
          const labelEl = document.getElementById('tri-label');

          if (anglesEl) anglesEl.textContent = `${angleA.toFixed(1)}° / ${angleB.toFixed(1)}° / ${angleC.toFixed(1)}°`;
          if (areaEl) areaEl.textContent = `${area.toFixed(4)} sq units`;
          if (perimeterEl) perimeterEl.textContent = `${perimeter.toFixed(2)} units`;
          if (labelEl) labelEl.textContent = triType;

          // Update SVG triangle visualization
          const polygon = document.getElementById('tri-polygon');
          if (polygon) {
            // Simple visualization based on angles
            const cx = 50, baseY = 90;
            const scale = 35;
            const radA = angleA * Math.PI / 180;
            const x1 = cx - scale, y1 = baseY;
            const x2 = cx + scale, y2 = baseY;
            const tipX = x1 + 2 * scale * Math.cos(radA);
            const tipY = baseY - 2 * scale * Math.sin(radA);
            polygon.setAttribute('points', `${x1},${y1} ${x2},${y2} ${tipX.toFixed(1)},${tipY.toFixed(1)}`);
          }
        };
      }
    }

    // --- Subnet Calculator ---
    if (slug === 'subnet-calculator') {
      const subCalcBtn = document.getElementById('sub-calculate');
      if (subCalcBtn) {
        subCalcBtn.onclick = () => {
          const ipStr = (document.getElementById('sub-ip') as HTMLInputElement)?.value || '192.168.1.1';
          const cidr = parseInt((document.getElementById('sub-cidr') as HTMLSelectElement)?.value) || 24;

          const octets = ipStr.split('.').map(Number);
          if (octets.length !== 4 || octets.some(o => isNaN(o) || o < 0 || o > 255)) {
            const maskEl = document.getElementById('sub-mask');
            if (maskEl) maskEl.textContent = 'Invalid IP';
            return;
          }

          // Compute subnet mask
          const maskBits = cidr;
          const mask = maskBits === 0 ? 0 : (~0 << (32 - maskBits)) >>> 0;
          const maskOctets = [(mask >>> 24) & 255, (mask >>> 16) & 255, (mask >>> 8) & 255, mask & 255];

          // IP as 32-bit integer
          const ipInt = ((octets[0] << 24) | (octets[1] << 16) | (octets[2] << 8) | octets[3]) >>> 0;

          // Network and Broadcast
          const netInt = (ipInt & mask) >>> 0;
          const broadInt = (netInt | (~mask >>> 0)) >>> 0;
          const toIP = (n: number) => `${(n >>> 24) & 255}.${(n >>> 16) & 255}.${(n >>> 8) & 255}.${n & 255}`;

          const hosts = Math.max(0, Math.pow(2, 32 - cidr) - 2);

          const maskEl = document.getElementById('sub-mask');
          const netEl = document.getElementById('sub-net');
          const broadEl = document.getElementById('sub-broadcast');
          const hostsEl = document.getElementById('sub-hosts');

          if (maskEl) maskEl.textContent = maskOctets.join('.');
          if (netEl) netEl.textContent = toIP(netInt);
          if (broadEl) broadEl.textContent = toIP(broadInt);
          if (hostsEl) hostsEl.textContent = hosts.toLocaleString() + ' hosts';
        };
      }
    }

    // --- Screen Size Calculator ---
    if (slug === 'screen-size-calculator') {
      // Tab switching
      const tabs = document.querySelectorAll('.calib-tab');
      const methods = document.querySelectorAll('.calib-method');
      tabs.forEach(tab => {
        (tab as HTMLButtonElement).onclick = () => {
          tabs.forEach(t => {
            (t as HTMLElement).className = 'calib-tab px-4 py-2 rounded-md text-[11px] font-bold text-mute hover:text-ink transition-all uppercase tracking-wider';
          });
          (tab as HTMLElement).className = 'calib-tab px-4 py-2 rounded-md text-[11px] font-bold bg-canvas text-ink shadow-sm border border-hairline uppercase tracking-wider';
          const target = tab.getAttribute('data-target');
          methods.forEach(m => {
            (m as HTMLElement).classList.add('hidden');
          });
          const targetEl = document.getElementById(`method-${target}`);
          if (targetEl) targetEl.classList.remove('hidden');
        };
      });

      // Auto-Detect
      const autoBtn = document.getElementById('run-auto-detect');
      if (autoBtn) {
        autoBtn.onclick = () => {
          const w = screen.width, h = screen.height;
          const dpr = window.devicePixelRatio || 1;
          const colorDepth = screen.colorDepth;
          const physW = w * dpr, physH = h * dpr;

          document.getElementById('auto-res')!.textContent = `${physW} × ${physH} px`;
          document.getElementById('auto-dpr')!.textContent = `${dpr}x`;
          document.getElementById('auto-color')!.textContent = `${colorDepth}-bit`;

          // Estimate diagonal (assuming 96 DPI as baseline)
          const diagPx = Math.sqrt(physW * physW + physH * physH);
          const estDiag = diagPx / (96 * dpr);
          document.getElementById('auto-est-size')!.textContent = `~${estDiag.toFixed(1)}" diagonal`;
        };
      }

      // Diagonal method
      const diagBtn = document.getElementById('run-diag-calc');
      if (diagBtn) {
        diagBtn.onclick = () => {
          const diag = parseFloat((document.getElementById('diag-size') as HTMLInputElement).value) || 15.6;
          const resX = parseFloat((document.getElementById('diag-res-x') as HTMLInputElement).value) || 1920;
          const resY = parseFloat((document.getElementById('diag-res-y') as HTMLInputElement).value) || 1080;

          const diagPx = Math.sqrt(resX * resX + resY * resY);
          const ppi = diagPx / diag;
          const widthIn = resX / ppi;
          const heightIn = resY / ppi;

          document.getElementById('diag-width')!.textContent = `${widthIn.toFixed(2)}" (${(widthIn * 2.54).toFixed(1)} cm)`;
          document.getElementById('diag-height')!.textContent = `${heightIn.toFixed(2)}" (${(heightIn * 2.54).toFixed(1)} cm)`;
          document.getElementById('diag-ppi')!.textContent = `${ppi.toFixed(1)} PPI`;
        };
      }

      // Credit Card Calibration
      const cardSlider = document.getElementById('card-slider') as HTMLInputElement;
      const visualCard = document.getElementById('visual-card') as HTMLElement;
      const sliderLabel = document.getElementById('slider-pixel-width');
      const cardCalcBtn = document.getElementById('run-card-calc');

      if (cardSlider && visualCard) {
        cardSlider.oninput = () => {
          const w = parseInt(cardSlider.value);
          visualCard.style.width = `${w}px`;
          visualCard.style.height = `${w * 0.6304}px`;
          if (sliderLabel) sliderLabel.textContent = `${w} px`;
        };
      }

      if (cardCalcBtn) {
        cardCalcBtn.onclick = () => {
          const cardWidthPx = parseInt(cardSlider?.value || '337');
          const cardRealWidth = 3.375; // standard credit card width in inches
          const ppi = cardWidthPx / cardRealWidth;
          const screenDiagPx = Math.sqrt(screen.width * screen.width + screen.height * screen.height);
          const dpr = window.devicePixelRatio || 1;
          const diag = (screenDiagPx * dpr) / ppi;

          document.getElementById('card-ppi')!.textContent = `${ppi.toFixed(1)} PPI`;
          document.getElementById('card-est-diag')!.textContent = `~${diag.toFixed(1)}"`;
        };
      }
    }

    // ==================== HELPERS ====================

    function setPrimary(v: string, l: string) {
      if (primaryVal) { 
        primaryVal.textContent = v; 
        primaryVal.className = 'text-6xl font-black text-link tracking-tighter transition-all';
        primaryVal.style.cursor = 'pointer';
        primaryVal.setAttribute('title', 'Click to copy result');
        primaryVal.onclick = () => {
          if (v && v !== '-') {
            navigator.clipboard.writeText(v).then(() => {
              primaryVal.className = 'text-6xl font-black text-emerald-500 tracking-tighter transition-all';
              setTimeout(() => {
                primaryVal.className = 'text-6xl font-black text-link tracking-tighter transition-all';
              }, 800);
            });
          }
        };
      }
      if (primaryLabel) primaryLabel.textContent = l;

      // History logger
      if (v && v !== '-' && calcForm && (window as any).zcalculate_saveToHistoryDebounced) {
        const currentUrl = window.location.pathname.split('/').filter(Boolean).pop() || 'calculator';
        const calcName = document.querySelector('h1')?.textContent?.replace(/\.$/, '') || currentUrl;
        
        const inputsList = Array.from(calcForm.elements)
          .filter((el: any) => el.name && el.value !== undefined && el.type !== 'submit')
          .map((el: any) => `${el.name.replace(/_/g, ' ')}: ${el.value}`)
          .join(', ');
        
        (window as any).zcalculate_saveToHistoryDebounced(calcName, inputsList || 'Parameters', `${l}: ${v}`);
      }
    }

    function addSecondary(l: string, v: string) {
      if (secondaryGrid) secondaryGrid.innerHTML += `<div class="bg-canvas-soft border border-hairline p-5 rounded-2xl"><span class="text-[10px] text-mute font-bold uppercase tracking-widest">${l}</span><div class="text-xl font-black text-ink mt-1">${v}</div></div>`;
    }

    function showBreakdownTable(headers: string[], rows: string[][]) {
      if (breakdownContainer && breakdownTable) {
        breakdownContainer.classList.remove('hidden');
        let h = `<thead><tr class="text-mute border-b border-hairline pb-3">${headers.map(th => `<th class="pb-3 pr-4">${th}</th>`).join('')}</tr></thead><tbody>`;
        rows.forEach(row => {
          h += `<tr class="border-b border-hairline/10 hover:bg-canvas-soft">${row.map((cell, i) => `<td class="py-3 pr-4 ${i === row.length - 1 ? 'text-right font-black text-link' : i === 0 ? 'text-mute' : 'text-ink font-bold'}">${cell}</td>`).join('')}</tr>`;
        });
        breakdownTable.innerHTML = h + '</tbody>';
      }
    }

    // Fullscreen Toggle
    const fsBtn = document.getElementById('fullscreen-btn');
    const container = document.getElementById('calculator-container');
    if (fsBtn && container) {
      fsBtn.onclick = () => {
        if (!document.fullscreenElement) {
          container.requestFullscreen().catch(err => {
            console.error(`Fullscreen request failed: ${err.message}`);
          });
        } else {
          document.exitFullscreen();
        }
      };

      const updateButton = () => {
        if (document.fullscreenElement === container) {
          fsBtn.innerHTML = `
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 9L4 4m0 0h4M4 4v4m16-4l-5 5m5-5v4m0-4h-4M4 20l5-5m-5 5v-4m0 4h4m16 0l-5-5m5 5v-4m0 4h-4"></path>
            </svg>
            Exit Fullscreen
          `;
        } else {
          fsBtn.innerHTML = `
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-5h-4m4 0v4m0-4l-5 5M4 20v-4m0 4h4m-4 0l5-5m11 5h-4m4 0v-4m0 4l-5-5"></path>
            </svg>
            Fullscreen
          `;
        }
      };

      document.onfullscreenchange = updateButton;
    }

    // Community Comments System
    const commentForm = document.getElementById('comment-form') as HTMLFormElement;
    const commentsList = document.getElementById('comments-list');

    const DEFAULT_COMMENTS = [
      { name: "Julian Vance", rating: 5, text: "Excellent calculator page. It has extremely precise digits and calculations, and the stark design matches my monitor perfectly.", date: "2026-07-10T14:32:00.000Z" },
      { name: "Sophia K.", rating: 4, text: "The Retro sage green LCD feels very comfortable on the eyes. Instant results are very smooth.", date: "2026-07-11T09:15:00.000Z" }
    ];

    async function renderComments() {
      if (!commentsList) return;
      let comments = [];

      try {
        const dbComments = await zdb.getComments(slug);
        if (dbComments && dbComments.length > 0) {
          comments = dbComments;
        } else {
          comments = [...DEFAULT_COMMENTS];
        }
      } catch (err) {
        console.error('Failed to read comments from IndexedDB:', err);
        const key = `comments_${slug}`;
        const saved = localStorage.getItem(key);
        comments = saved ? JSON.parse(saved) : [...DEFAULT_COMMENTS];
      }

      commentsList.innerHTML = comments.map((c: any) => {
        const repliesHtml = (c.replies || []).map((r: any) => `
          <div class="ml-6 mt-3 bg-canvas border-l-2 border-hairline p-3 rounded-lg text-left space-y-1">
            <div class="flex items-center justify-between">
              <span class="font-bold text-ink text-[11px] font-sans">${r.name}</span>
              <span class="text-[8px] text-mute font-mono">${new Date(r.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
            </div>
            <p class="text-body text-xs font-sans">${r.text}</p>
          </div>
        `).join('');

        const commentId = c.id !== undefined ? c.id : (c.date ? c.date.replace(/[^0-9]/g, '') : Math.random().toString(36).substr(2, 5));

        return `
          <div class="bg-canvas-card-soft border border-canvas-card-border rounded-xl p-4 space-y-2 text-left" data-comment-id="${c.id || ''}">
            <div class="flex items-center justify-between">
              <span class="font-bold text-ink text-xs font-sans">${c.name}</span>
              <span class="text-amber-500 text-xs">${'★'.repeat(c.rating)}${'☆'.repeat(5 - c.rating)}</span>
            </div>
            <p class="text-body text-xs font-sans leading-relaxed">${c.text}</p>
            <div class="flex items-center justify-between mt-2 pt-1 border-t border-hairline/30">
              <button class="toggle-reply-btn text-[10px] font-bold text-link hover:underline uppercase tracking-wider" data-id="${commentId}">Reply</button>
              <div class="text-[9px] text-mute font-mono">${new Date(c.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
            </div>
            <!-- Replies -->
            <div class="space-y-2">${repliesHtml}</div>
            <!-- Reply Form -->
            <div id="reply-form-${commentId}" class="hidden mt-3 pl-6 space-y-2 border-l border-hairline">
              <input type="text" id="reply-name-${commentId}" placeholder="Your Name" class="w-full bg-canvas border border-canvas-card-border text-ink rounded-lg h-8 px-3 text-xs focus:outline-none focus:border-hairline-strong transition-all" />
              <textarea id="reply-text-${commentId}" placeholder="Write a reply..." rows="2" class="w-full bg-canvas border border-canvas-card-border text-ink rounded-lg p-2.5 text-xs focus:outline-none focus:border-hairline-strong transition-all resize-none"></textarea>
              <button class="submit-reply-btn px-4 py-1.5 bg-brand-primary text-canvas rounded-lg text-[10px] font-bold uppercase tracking-wider bg-[#171717]" data-id="${commentId}" data-real-id="${c.id !== undefined ? c.id : ''}">Submit Reply</button>
            </div>
          </div>
        `;
      }).join('');

      // Attach reply togglers
      commentsList.querySelectorAll('.toggle-reply-btn').forEach(btn => {
        (btn as HTMLButtonElement).onclick = () => {
          const id = btn.getAttribute('data-id');
          const form = document.getElementById(`reply-form-${id}`);
          if (form) {
            form.classList.toggle('hidden');
          }
        };
      });

      // Attach reply submit handlers
      commentsList.querySelectorAll('.submit-reply-btn').forEach(btn => {
        (btn as HTMLButtonElement).onclick = async () => {
          const id = btn.getAttribute('data-id');
          const realId = btn.getAttribute('data-real-id');
          const nameEl = document.getElementById(`reply-name-${id}`) as HTMLInputElement;
          const textEl = document.getElementById(`reply-text-${id}`) as HTMLTextAreaElement;
          
          if (!textEl.value.trim()) return;

          if (realId && (window as any).zdb) {
            try {
              await zdb.addReply(Number(realId), nameEl.value.trim() || 'Anonymous User', textEl.value.trim());
              renderComments();
            } catch (err) {
              console.error('Failed to submit reply:', err);
            }
          } else {
            alert('Replies are only supported for comments saved in the database.');
          }
        };
      });
    }

    if (commentForm) {
      commentForm.onsubmit = async (e) => {
        e.preventDefault();
        const nameEl = document.getElementById('comment-name') as HTMLInputElement;
        const ratingEl = document.getElementById('comment-rating') as HTMLSelectElement;
        const textEl = document.getElementById('comment-text') as HTMLTextAreaElement;

        const nameVal = nameEl.value.trim() || 'Anonymous User';
        const ratingVal = parseInt(ratingEl.value, 10);
        const textVal = textEl.value.trim();

        try {
          await zdb.addComment(slug, nameVal, ratingVal, textVal);
        } catch (err) {
          console.error('Failed to write comment to IndexedDB:', err);
          // localStorage fallback
          const key = `comments_${slug}`;
          const saved = localStorage.getItem(key);
          const comments = saved ? JSON.parse(saved) : [...DEFAULT_COMMENTS];
          comments.unshift({
            name: nameVal,
            rating: ratingVal,
            text: textVal,
            date: new Date().toISOString()
          });
          localStorage.setItem(key, JSON.stringify(comments));
        }
        
        nameEl.value = '';
        textEl.value = '';
        renderComments();
      };

      renderComments();
    }
  }

  // Initialization
  initCalculators();
  document.addEventListener('astro:after-swap', initCalculators);
  window.onload = initCalculators;
</script>
