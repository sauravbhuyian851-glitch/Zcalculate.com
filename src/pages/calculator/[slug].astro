      const display = document.getElementById('pass-display');
      const copyBtn = document.getElementById('pass-copy');
      const strengthEl = document.getElementById('pass-strength');
      const entropyEl = document.getElementById('pass-entropy');

      if (lenSlider && lenVal) {
        lenSlider.oninput = () => { lenVal.textContent = `${lenSlider.value} chars`; };
      }

      if (genBtn && display) {
        genBtn.onclick = () => {
          let chars = '';
          if ((document.getElementById('pass-upper') as HTMLInputElement)?.checked) chars += 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
          if ((document.getElementById('pass-lower') as HTMLInputElement)?.checked) chars += 'abcdefghijklmnopqrstuvwxyz';
          if ((document.getElementById('pass-numbers') as HTMLInputElement)?.checked) chars += '0123456789';
          if ((document.getElementById('pass-symbols') as HTMLInputElement)?.checked) chars += '!@#$%^&*()-_=+[]{}|;:,.<>?';
          
          if (chars.length === 0) {
            display.textContent = 'Select at least one option';
            return;
          }

          const length = parseInt(lenSlider?.value || '16');
          const array = new Uint32Array(length);
          crypto.getRandomValues(array);
          let password = '';
          for (let i = 0; i < length; i++) {
            password += chars[array[i] % chars.length];
          }
          display.textContent = password;

          // Entropy calculation
          const poolSize = chars.length;
          const entropy = Math.log2(poolSize) * length;
          if (entropyEl) entropyEl.textContent = `${entropy.toFixed(1)} bits`;

          // Strength assessment
          if (strengthEl) {
            if (entropy >= 80) { strengthEl.textContent = 'Very Strong'; strengthEl.className = 'text-base font-bold text-emerald-600'; }
            else if (entropy >= 60) { strengthEl.textContent = 'Strong'; strengthEl.className = 'text-base font-bold text-link'; }
            else if (entropy >= 40) { strengthEl.textContent = 'Moderate'; strengthEl.className = 'text-base font-bold text-amber-600'; }
            else { strengthEl.textContent = 'Weak'; strengthEl.className = 'text-base font-bold text-rose-600'; }
          }

          resultsPanel?.classList.remove('hidden');
          setPrimary('Generated', 'Secure Password Ready');
        };
      }

