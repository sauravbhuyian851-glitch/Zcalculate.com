      let expr = '';
      let isRadians = false;
      const resDisp = document.getElementById('sci-display-result');
      const exprDisp = document.getElementById('sci-display-expr');
      const degRadEl = document.getElementById('sci-deg-rad');
      const toggleRadBtn = document.getElementById('sci-toggle-rad');

      if (toggleRadBtn && degRadEl) {
        toggleRadBtn.onclick = () => {
          isRadians = !isRadians;
          degRadEl.textContent = isRadians ? 'RAD' : 'DEG';
          toggleRadBtn.textContent = isRadians ? 'Toggle DEG' : 'Toggle RAD';
        };
      }

      document.querySelectorAll('.sci-btn').forEach(b => {
        (b as HTMLButtonElement).onclick = () => {
          const v = b.getAttribute('data-sci');
          if (!v) return;

          if (v === '=') {
            try {
              let prep = expr.replace(/×/g, '*').replace(/÷/g, '/').replace(/π/g, 'Math.PI');
              // Replace standalone 'e' but not inside function names
              prep = prep.replace(/(?<![a-zA-Z])e(?![a-zA-Z])/g, 'Math.E');
              // Handle factorial
              prep = prep.replace(/(\d+(?:\.\d+)?)\!/g, (_, n) => {
                let r = 1; for (let i = 2; i <= parseFloat(n); i++) r *= i; return r.toString();
              });
              const d2r = Math.PI / 180;
              if (!isRadians) {
                prep = prep.replace(/sin\(/g, `Math.sin(${d2r}*`)
                           .replace(/cos\(/g, `Math.cos(${d2r}*`)
                           .replace(/tan\(/g, `Math.tan(${d2r}*`)
                           .replace(/asin\(/g, `(1/${d2r})*Math.asin(`)
                           .replace(/acos\(/g, `(1/${d2r})*Math.acos(`)
                           .replace(/atan\(/g, `(1/${d2r})*Math.atan(`);
              } else {
                prep = prep.replace(/sin\(/g, 'Math.sin(')
                           .replace(/cos\(/g, 'Math.cos(')
                           .replace(/tan\(/g, 'Math.tan(')
                           .replace(/asin\(/g, 'Math.asin(')
                           .replace(/acos\(/g, 'Math.acos(')
                           .replace(/atan\(/g, 'Math.atan(');
              }
              prep = prep.replace(/ln\(/g, 'Math.log(')
                         .replace(/log\(/g, 'Math.log10(')
                         .replace(/sqrt\(/g, 'Math.sqrt(')
                         .replace(/\^/g, '**');

              const result = new Function(`return ${prep}`)();
              if (resDisp) resDisp.textContent = typeof result === 'number' && !isNaN(result) ? Number(result.toFixed(10)).toString() : 'Error';
              expr = typeof result === 'number' ? result.toString() : '';
            } catch (e) {
              if (resDisp) resDisp.textContent = 'Error';
            }
          }
          else if (v === 'clear') {
            expr = '';
            if (resDisp) resDisp.textContent = '0';
            if (exprDisp) exprDisp.textContent = '\u00A0';
          }
          else if (v === 'back') {
            const funcMatch = ['asin(', 'acos(', 'atan(', 'sin(', 'cos(', 'tan(', 'log(', 'ln(', 'sqrt('].find(f => expr.endsWith(f));
            expr = funcMatch ? expr.substring(0, expr.length - funcMatch.length) : expr.substring(0, expr.length - 1);
            if (exprDisp) exprDisp.textContent = expr || '\u00A0';
            if (!expr && resDisp) resDisp.textContent = '0';
          }
          else if (v === 'pct') {
            expr += '%';
            if (exprDisp) exprDisp.textContent = expr;
          }
          else {
            let insert = v;
            if (['sin', 'cos', 'tan', 'asin', 'acos', 'atan', 'log', 'ln', 'sqrt'].includes(v)) insert = v + '(';
            else if (v === 'fact') insert = '!';
            else if (v === 'pi') insert = 'π';
            else if (v === 'pow') insert = '^';
            else if (v === 'open') insert = '(';
            else if (v === 'close') insert = ')';
            else if (v === 'e') insert = 'e';

            expr += insert;
            if (exprDisp) exprDisp.textContent = expr;
          }
        };
      });
