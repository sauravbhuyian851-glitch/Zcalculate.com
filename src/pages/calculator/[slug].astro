---
import Layout from '../../layouts/Layout.astro';
import SpecializedCalculatorUIs from '../../components/SpecializedCalculatorUIs.astro';
import { calculatorsList } from '../../data/calculators';

export async function getStaticPaths() {
  return calculatorsList.map(calc => ({
    params: { slug: calc.slug },
    props: { calc }
  }));
}

const { calc } = Astro.props;
const relatedCalcs = calculatorsList.filter(c => calc.relatedSlugs.includes(c.slug));
const canonicalUrl = `https://zcalculate.com/calculator/${calc.slug}`;

const cleanName = calc.name.replace(/\(.*\)/g, '').trim().toLowerCase();
const nameBase = cleanName.endsWith('calculator') ? cleanName : `${cleanName} calculator`;
const keywordsList = [
  nameBase,
  `free online ${nameBase}`,
  `${cleanName} solver`,
  `how to calculate ${cleanName.replace('calculator', '').trim()}`,
  `calculate ${cleanName.replace('calculator', '').trim()}`,
  calc.category,
  ...calc.relatedSlugs.map(s => s.replace(/-/g, ' '))
];
const pageKeywords = keywordsList.join(', ');

// JSON-LD WebApplication schema
const webAppSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": calc.name,
  "url": canonicalUrl,
  "description": calc.seoDescription,
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "browserRequirements": "Requires JavaScript",
  "creator": {
    "@type": "Organization",
    "name": "Zcalculate"
  }
};

// JSON-LD FAQPage schema
const faqSchema = calc.faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": calc.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
} : null;

// BreadcrumbList schema
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://zcalculate.com/" },
    { "@type": "ListItem", "position": 2, "name": "Calculators", "item": "https://zcalculate.com/#all-calculators" },
    { "@type": "ListItem", "position": 3, "name": calc.name, "item": canonicalUrl }
  ]
};
---
<Layout title={calc.seoTitle} description={calc.seoDescription} canonicalUrl={canonicalUrl} ogType="website" keywords={pageKeywords}>
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(webAppSchema)} is:inline slot="head" />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline slot="head" />}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} is:inline slot="head" />

  <div class="mx-auto max-w-5xl px-6 py-16">
    <!-- Breadcrumb Navigation -->
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-2 text-[11px] font-mono text-mute uppercase tracking-widest">
        <li><a href="/" class="hover:text-ink transition-colors">Home</a></li>
        <li class="text-hairline-strong">/</li>
        <li><a href="/#all-calculators" class="hover:text-ink transition-colors">Calculators</a></li>
        <li class="text-hairline-strong">/</li>
        <li class="text-ink font-bold">{calc.name}</li>
      </ol>
    </nav>

    <!-- Back to home -->
    <a href="/#all-calculators" class="inline-flex items-center gap-2 text-[11px] font-bold text-mute hover:text-ink transition-colors uppercase tracking-widest mb-10 group">
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
      Library Index
    </a>

    <!-- Calculator Title Headers -->
    <div class="border-b border-hairline pb-10 mb-12 text-left">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block px-2.5 py-1 bg-canvas-soft border border-hairline text-[10px] font-bold text-mute rounded-md uppercase tracking-wider">{calc.category}</span>
        <span class="text-hairline-strong font-mono text-xs">/</span>
        <span class="text-mute text-xs font-semibold uppercase tracking-tight">Free Online Tool</span>
      </div>
      <h1 class="display-lg text-ink">{calc.name}.</h1>
      <p class="text-body text-lg mt-3 leading-relaxed max-w-2xl">{calc.description}</p>
    </div>

    <!-- Main Flex Grid split -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      
      <!-- Inputs Column (Forms or Custom UIs) -->
      <div class="lg:col-span-5 space-y-6">
        <div class="bg-canvas border border-hairline rounded-2xl p-8 shadow-xl text-left">
          <h2 class="text-[11px] font-bold text-mute mb-8 font-mono uppercase tracking-[0.2em] border-b border-hairline pb-3">Input Parameters</h2>
          
          {calc.customUI ? (
            <!-- Custom Interactive Calculator UI -->
            <SpecializedCalculatorUIs type={calc.slug} />
          ) : (
            <!-- Standard Form-Based Layout -->
            <form id="calc-form" class="space-y-6">
              {calc.inputs.map(input => (
                <div>
                  <label for={input.id} class="block text-[11px] font-bold text-mute uppercase tracking-wider mb-2">{input.label}</label>
                  
                  <div class="relative rounded-lg">
                    {input.type === 'select' ? (
                      <select id={input.id} name={input.id} class="w-full bg-canvas-soft border border-hairline text-ink rounded-lg h-12 px-4 text-base font-bold focus:outline-none focus:border-hairline-strong focus:ring-4 focus:ring-canvas-soft transition-all appearance-none cursor-pointer">
                        {input.options?.map(opt => (
                          <option value={opt.value} selected={opt.value == input.default ? true : undefined}>{opt.label}</option>
                        ))}
                      </select>
                    ) : input.type === 'checkbox' ? (
                      <label class="flex items-center gap-3 cursor-pointer py-3 text-base font-bold text-body">
                        <input type="checkbox" id={input.id} name={input.id} checked={input.default ? true : undefined} class="accent-link h-6 w-6 rounded border-hairline" />
                        <span>Enable this option</span>
                      </label>
                    ) : input.type === 'date' ? (
                      <div class="space-y-3 w-full">
                        <div>
                          <span class="block text-[9px] font-bold text-mute uppercase tracking-wider mb-1">Manual Keyboard Input / Calendar</span>
                          <input 
                            type="date" 
                            id={input.id} 
                            name={input.id} 
                            value={input.default} 
                            class="w-full bg-canvas-soft border border-hairline text-ink rounded-lg h-12 px-4 text-base font-bold focus:outline-none focus:border-hairline-strong focus:ring-4 focus:ring-canvas-soft transition-all calc-date-input"
                            required
                          />
                        </div>
                        <div>
                          <span class="block text-[9px] font-bold text-mute uppercase tracking-wider mb-1">Dropdown Selectors</span>
                          <div class="grid grid-cols-3 gap-2">
                            <select id={`${input.id}-month`} class="bg-canvas-soft border border-hairline text-ink rounded-lg h-12 px-2 text-sm font-bold focus:outline-none focus:border-hairline-strong cursor-pointer calc-date-select-month">
                              {Array.from({ length: 12 }, (_, i) => {
                                const m = i + 1;
                                const name = new Date(2000, i, 1).toLocaleString('en-US', { month: 'short' });
                                return <option value={m}>{name}</option>;
                              })}
                            </select>
                            
                            <select id={`${input.id}-day`} class="bg-canvas-soft border border-hairline text-ink rounded-lg h-12 px-2 text-sm font-bold focus:outline-none focus:border-hairline-strong cursor-pointer calc-date-select-day">
                              {Array.from({ length: 31 }, (_, i) => {
                                const d = i + 1;
                                return <option value={d}>{d}</option>;
                              })}
                            </select>
                            
                            <select id={`${input.id}-year`} class="bg-canvas-soft border border-hairline text-ink rounded-lg h-12 px-2 text-sm font-bold focus:outline-none focus:border-hairline-strong cursor-pointer calc-date-select-year">
                              {Array.from({ length: 151 }, (_, i) => {
                                const y = 1900 + i;
                                return <option value={y}>{y}</option>;
                              })}
                            </select>
                          </div>
                        </div>
                      </div>
                    ) : (
                      <input 
                        type={input.type} 
                        id={input.id} 
                        name={input.id} 
                        value={input.default} 
                        placeholder={input.placeholder}
                        class="w-full bg-canvas-soft border border-hairline text-ink rounded-lg h-12 px-4 text-base font-bold focus:outline-none focus:border-hairline-strong focus:ring-4 focus:ring-canvas-soft transition-all"
                        required
                      />
                    )}
                    {input.unit && (
                      <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4">
                        <span class="text-[10px] font-bold font-mono text-mute uppercase">{input.unit}</span>
                      </div>
                    )}
                  </div>
                </div>
              ))}
              
              <button type="submit" id="calc-submit-btn" class="w-full h-16 rounded-2xl bg-brand-primary hover:opacity-90 text-canvas font-black text-xl transition-all shadow-xl mt-8 flex items-center justify-center gap-4 tracking-tighter uppercase">
                <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
                CALCULATE RESULTS
              </button>
            </form>
          )}
        </div>
      </div>

      <!-- Outputs / Results Display Column -->
      <div id="results-panel" class="hidden lg:col-span-7 space-y-8 text-left">
        <div class="bg-canvas border border-hairline rounded-2xl p-8 shadow-xl">
          <h2 class="text-[11px] font-bold text-mute mb-8 font-mono uppercase tracking-[0.2em] border-b border-hairline pb-3">Computed Results</h2>
          
          <!-- Large Prominent Display Card -->
          <div class="bg-canvas-soft border border-hairline rounded-2xl p-8 text-center shadow-inner mb-8">
            <span class="text-[10px] font-bold font-mono text-mute uppercase tracking-[0.2em] block mb-2">Primary Metric</span>
            <div id="result-primary-val" class="text-6xl font-black text-link tracking-tighter">-</div>
            <div id="result-primary-label" class="text-sm font-semibold text-body mt-2">-</div>
          </div>

          <!-- Secondary Metrics Grid -->
          <div class="grid grid-cols-2 gap-4" id="result-secondary-grid">
            <!-- Filled dynamically -->
          </div>
        </div>

        <!-- Progressive Disclosure: Amortization/Breakdown Tables -->
        <div id="breakdown-container" class="hidden">
          <button id="breakdown-toggle" class="flex w-full items-center justify-between p-5 bg-canvas border border-hairline rounded-2xl hover:border-hairline-strong transition-all shadow-sm">
            <span class="text-[11px] font-bold text-body uppercase tracking-widest flex items-center gap-3">
              <svg class="w-4 h-4 text-link" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 10h18M3 14h18m-9-4v8m-7 0h14" stroke-linecap="round" stroke-linejoin="round"/></svg>
              Detailed Breakdown
            </span>
            <svg id="breakdown-arrow" class="w-4 h-4 text-mute transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"></path></svg>
          </button>
          <div id="breakdown-table-wrapper" class="hidden mt-4 bg-canvas border border-hairline rounded-2xl overflow-hidden shadow-inner p-4 overflow-x-auto">
            <table class="w-full font-mono text-[11px] text-left" id="breakdown-table">
              <!-- Rendered dynamically -->
            </table>
          </div>
        </div>

      </div>

    </div>

    <!-- FAQ Section (SEO + UX) -->
    {calc.faqs.length > 0 && (
      <section class="mt-24 border-t border-hairline pt-16">
        <h2 class="display-lg text-ink mb-10">Frequently asked questions.</h2>
        <div class="space-y-6 max-w-3xl">
          {calc.faqs.map(faq => (
            <details class="group bg-canvas border border-hairline rounded-xl p-6 shadow-sm hover:shadow-md transition-all">
              <summary class="text-base font-semibold text-ink cursor-pointer list-none flex items-center justify-between gap-4">
                {faq.question}
                <svg class="w-5 h-5 text-mute transition-transform group-open:rotate-180 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <p class="mt-4 text-body text-sm leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>
    )}

    <!-- Related Calculators Section (Internal Linking for SEO) -->
    {relatedCalcs.length > 0 && (
      <section class="mt-24 border-t border-hairline pt-16">
        <h2 class="display-lg text-ink mb-4">Related calculators.</h2>
        <p class="text-body text-base mb-10">Explore more tools that complement this calculator.</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {relatedCalcs.map(rc => (
            <a href={`/calculator/${rc.slug}`} class="group p-6 bg-canvas border border-hairline hover:border-hairline-strong rounded-xl transition-all hover:shadow-lg">
              <div class="flex items-center gap-3 mb-3">
                <span class="inline-block px-2 py-0.5 bg-canvas-soft border border-hairline text-[9px] font-bold text-mute rounded uppercase tracking-wider">{rc.category}</span>
              </div>
              <h3 class="text-base font-semibold text-ink group-hover:text-link transition-colors">{rc.name}</h3>
              <p class="mt-2 text-sm text-body leading-relaxed line-clamp-2">{rc.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

  </div>
</Layout>

<script>
  import * as calcMath from '../../utils/calculatorMath';

  function initCalculators() {
    const slug = window.location.pathname.split('/').filter(Boolean).pop() || '';
    const calcForm = document.getElementById('calc-form') as HTMLFormElement;
    const resultsPanel = document.getElementById('results-panel');
    const primaryVal = document.getElementById('result-primary-val');
    const primaryLabel = document.getElementById('result-primary-label');
    const secondaryGrid = document.getElementById('result-secondary-grid');
    
    // Select dynamic elements
    const breakdownToggle = document.getElementById('breakdown-toggle');
    const breakdownWrapper = document.getElementById('breakdown-table-wrapper');
    const breakdownArrow = document.getElementById('breakdown-arrow');
    const breakdownContainer = document.getElementById('breakdown-container');
    const breakdownTable = document.getElementById('breakdown-table');

    // Attach Toggle Events
    if (breakdownToggle && breakdownWrapper && breakdownArrow) {
      breakdownToggle.onclick = () => {
        breakdownWrapper.classList.toggle('hidden');
        breakdownArrow.classList.toggle('rotate-180');
      };
    }

    // Standard Form Logic
    if (calcForm) {
      const runForm = () => {
        const formData = new FormData(calcForm);
        const data: Record<string, any> = {};
        formData.forEach((val, key) => {
          const inputEl = calcForm.querySelector(`[name="${key}"]`) as HTMLInputElement | HTMLSelectElement;
          if (inputEl) {
            if (inputEl.type === 'checkbox') {
              data[key] = (inputEl as HTMLInputElement).checked;
            } else if (inputEl.type === 'number' || inputEl.type === 'range') {
              data[key] = parseFloat(val as string);
            } else if (inputEl.tagName === 'SELECT') {
              const numVal = parseFloat(val as string);
              data[key] = isNaN(numVal) ? val : numVal;
            } else {
              data[key] = val;
            }
          } else {
            const numVal = parseFloat(val as string);
            data[key] = isNaN(numVal) ? val : numVal;
          }
        });
        // Handle checkbox (not included in FormData when unchecked)
        const checkboxes = calcForm.querySelectorAll('input[type="checkbox"]');
        checkboxes.forEach((cb) => {
          const checkbox = cb as HTMLInputElement;
          data[checkbox.name] = checkbox.checked;
        });
        evaluateForm(data);
      };
      // Synchronization for date inputs and dropdown selects
      const dateInputs = calcForm.querySelectorAll('.calc-date-input');
      dateInputs.forEach(di => {
        const dateInput = di as HTMLInputElement;
        const id = dateInput.id;
        const monthSelect = document.getElementById(`${id}-month`) as HTMLSelectElement;
        const daySelect = document.getElementById(`${id}-day`) as HTMLSelectElement;
        const yearSelect = document.getElementById(`${id}-year`) as HTMLSelectElement;

        if (monthSelect && daySelect && yearSelect) {
          const syncSelectsFromInput = () => {
            const val = dateInput.value;
            if (val) {
              const parts = val.split('-');
              if (parts.length === 3) {
                const year = parseInt(parts[0], 10);
                const month = parseInt(parts[1], 10);
                const day = parseInt(parts[2], 10);
                monthSelect.value = String(month);
                daySelect.value = String(day);
                yearSelect.value = String(year);
              }
            }
          };

          const syncInputFromSelects = () => {
            const year = yearSelect.value;
            const month = String(monthSelect.value).padStart(2, '0');
            const day = String(daySelect.value).padStart(2, '0');
            dateInput.value = `${year}-${month}-${day}`;
            dateInput.dispatchEvent(new Event('input', { bubbles: true }));
          };

          monthSelect.onchange = syncInputFromSelects;
          daySelect.onchange = syncInputFromSelects;
          yearSelect.onchange = syncInputFromSelects;

          dateInput.onchange = syncSelectsFromInput;
          dateInput.addEventListener('input', syncSelectsFromInput);

          // Initial sync
          syncSelectsFromInput();
        }
      });

      calcForm.onsubmit = (e) => { e.preventDefault(); runForm(); };
      calcForm.oninput = runForm;
      // Also handle checkbox changes
      calcForm.querySelectorAll('input[type="checkbox"]').forEach(cb => {
        (cb as HTMLInputElement).onchange = runForm;
      });
      runForm();
    }

    function evaluateForm(data: Record<string, any>) {
      if (!resultsPanel) return;
      resultsPanel.classList.remove('hidden');
      if (breakdownContainer) breakdownContainer.classList.add('hidden');
      if (secondaryGrid) secondaryGrid.innerHTML = '';

      // ==================== FINANCIAL CALCULATORS ====================

      if (slug === 'mortgage-calculator') {
        const res = calcMath.calculateMortgage(data.home_value, data.down_payment, data.interest_rate, data.loan_term);
        setPrimary(`$${res.monthlyPayment.toFixed(2)}`, 'Estimated Monthly Payment');
        addSecondary('Loan Principal', `$${res.principal.toLocaleString()}`);
        addSecondary('Total Interest', `$${Math.round(res.totalInterest).toLocaleString()}`);
        addSecondary('Total Loan Cost', `$${Math.round(res.totalCost).toLocaleString()}`);
        addSecondary('Payoff Period', `${data.loan_term} years`);
        showBreakdownTable(
          ['Year', 'Paid', 'Interest', 'Balance'],
          res.schedule.map(r => [`Yr ${r.year}`, `$${Math.round(r.accumulatedPrincipal).toLocaleString()}`, `$${Math.round(r.accumulatedInterest).toLocaleString()}`, `$${Math.round(r.balance).toLocaleString()}`])
        );
      }
      else if (slug === 'loan-calculator') {
        const res = calcMath.calculateLoan(data.loan_amount, data.interest_rate, data.loan_term);
        setPrimary(`$${res.monthlyPayment.toFixed(2)}`, 'Monthly Payment');
        addSecondary('Principal', `$${data.loan_amount.toLocaleString()}`);
        addSecondary('Total Interest', `$${Math.round(res.totalInterest).toLocaleString()}`);
        addSecondary('Total Cost', `$${Math.round(res.totalCost).toLocaleString()}`);
        addSecondary('Term', `${data.loan_term} years`);
      }
      else if (slug === 'auto-loan-calculator') {
        const res = calcMath.calculateAutoLoan(data.auto_price, data.down_payment, data.trade_in, data.interest_rate, data.loan_term, data.sales_tax);
        setPrimary(`$${res.monthlyPayment.toFixed(2)}`, 'Monthly Auto Payment');
        addSecondary('Financed Amount', `$${res.principal.toLocaleString()}`);
        addSecondary('Sales Tax', `$${res.taxAmount.toFixed(2)}`);
        addSecondary('Total Interest', `$${Math.round(res.totalInterest).toLocaleString()}`);
        addSecondary('Total Cost', `$${Math.round(res.totalCost).toLocaleString()}`);
      }
      else if (slug === 'interest-calculator') {
        const res = calcMath.calculateInterest(data.principal, data.interest_rate, data.time_years, data.compound_type);
        setPrimary(`$${res.totalBalance.toFixed(2)}`, `Total Balance (${data.compound_type === 'simple' ? 'Simple' : 'Compound'})`);
        addSecondary('Principal', `$${data.principal.toLocaleString()}`);
        addSecondary('Interest Earned', `$${res.totalInterest.toFixed(2)}`);
        addSecondary('Duration', `${data.time_years} years`);
        addSecondary('Rate', `${data.interest_rate}%`);
      }
      else if (slug === 'payment-calculator') {
        const res = calcMath.calculatePayment(data.item_price, data.down_payment, data.interest_rate, data.term_months);
        setPrimary(`$${res.monthlyPayment.toFixed(2)}`, 'Monthly Payment');
        addSecondary('Financed Amount', `$${(data.item_price - data.down_payment).toLocaleString()}`);
        addSecondary('Total Interest', `$${res.totalInterest.toFixed(2)}`);
        addSecondary('Total Cost', `$${res.totalCost.toFixed(2)}`);
        addSecondary('Term', `${data.term_months} months`);
      }
      else if (slug === 'retirement-calculator') {
        const res = calcMath.calculateRetirement(data.current_age, data.retirement_age, data.current_savings, data.monthly_deposit, data.return_rate, data.inflation_rate);
        setPrimary(`$${Math.round(res.balanceAtRetirement).toLocaleString()}`, 'Projected Balance at Retirement');
        addSecondary('Total Deposits', `$${Math.round(res.totalDeposits).toLocaleString()}`);
        addSecondary('Interest Earned', `$${Math.round(res.interestEarned).toLocaleString()}`);
        addSecondary('Monthly Income (4% rule)', `$${res.monthlyRetirementIncome.toFixed(2)}`);
        addSecondary('Years to Retire', `${data.retirement_age - data.current_age} years`);
      }
      else if (slug === 'amortization-calculator') {
        const res = calcMath.calculateMortgage(data.loan_amount + 0, 0, data.interest_rate, data.loan_term);
        setPrimary(`$${res.monthlyPayment.toFixed(2)}`, 'Monthly Payment');
        addSecondary('Loan Amount', `$${data.loan_amount.toLocaleString()}`);
        addSecondary('Total Interest', `$${Math.round(res.totalInterest).toLocaleString()}`);
        addSecondary('Total Cost', `$${Math.round(res.totalCost).toLocaleString()}`);
        addSecondary('Duration', `${data.loan_term} years (${data.loan_term * 12} payments)`);
        showBreakdownTable(
          ['Year', 'Principal Paid', 'Interest Paid', 'Remaining'],
          res.schedule.map(r => [`Yr ${r.year}`, `$${Math.round(r.accumulatedPrincipal).toLocaleString()}`, `$${Math.round(r.accumulatedInterest).toLocaleString()}`, `$${Math.round(r.balance).toLocaleString()}`])
        );
      }
      else if (slug === 'investment-calculator') {
        const res = calcMath.calculateInvestment(data.starting_amount, data.monthly_contribution, data.annual_return, data.years);
        setPrimary(`$${Math.round(res.endBalance).toLocaleString()}`, 'Projected End Balance');
        addSecondary('Starting Capital', `$${data.starting_amount.toLocaleString()}`);
        addSecondary('Total Contributions', `$${Math.round(res.totalContributions).toLocaleString()}`);
        addSecondary('Interest Earned', `$${Math.round(res.totalInterest).toLocaleString()}`);
        addSecondary('Time Horizon', `${data.years} years`);
      }
      else if (slug === 'inflation-calculator') {
        const res = calcMath.calculateInflation(data.starting_amount, data.inflation_rate, data.years);
        setPrimary(`$${res.purchasingPower.toFixed(2)}`, `Purchasing Power of $${data.starting_amount} in ${data.years} years`);
